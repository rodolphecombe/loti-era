msgstr "mieux protégé contre les attaques physiques (3% de résistance supplémentaire; +5% de résistance au contondant)"

#. [advancement], id=darken
#: .\units\Blackguard.cfg:104
msgid "able to darken even the night"
msgstr "capable d'obscurcir même la nuit"

#. [advancement], id=darken2
