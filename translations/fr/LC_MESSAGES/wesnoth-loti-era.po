#: .\utils\abilities.cfg:1955
#: .\utils\abilities.cfg:1977
msgid "leeches"
msgstr "sangsue"

#. [dummy], id=leech_loti
#: .\utils\abilities.cfg:1956
msgid "All adjacent enemy units to a unit with this ability lose 2 hitpoints at the beginning of this unit's turn. The damage dealt heals the unit. It cannot kill."
