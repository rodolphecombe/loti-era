msgstr "faire que les ennemis proches infligent encore moins de dégâts"

#. [unit_type], id=09 Ancient Lich, race=undead
#: .\units\Ancient_Lich.cfg:20
msgid "A being of this order is a revenant of ages long past. Anyone who encounters an Ancient Lich likely has far worse things to worry about than death."
msgstr "Un être de cet ordre est un revenant d'un âge depuis longtemps révolu. Qui rencontre une ancienne liche a probablement des choses bien pire à redouter que la mort. "

#. [advancement], id=melee2
#. [advancement], id=melee3
#: .\units\Ancient_Lich.cfg:175
#: .\units\Demilich.cfg:197
msgid "creating zombies from enemies killed at melee"
msgstr "créer des zombies à partir d'ennemis tués au corps-à-corps"

#. [advancement], id=magic-chill3
#: .\units\Ancient_Lich.cfg:192
#: .\units\Demilich.cfg:214
msgid "slowing with chill tempest"
msgstr "ralentir avec la tempête glaciale"

#. [advancement], id=magic-chill-slow-extra
#: .\units\Ancient_Lich.cfg:209
