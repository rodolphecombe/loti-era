#. [value]
#. [trait], id=healthy
#: .\utils\global_events.cfg:1316
#: .\utils\utils.cfg:265
msgid "highlander"
msgstr "highlander"

#. [value]
#. [trait], id=healthy
#: .\utils\global_events.cfg:1317
#: .\utils\utils.cfg:266
msgid "female^highlander"
msgstr "highlander"

#. [value]
#. [trait], id=healthy
#: .\utils\global_events.cfg:1319
#: .\utils\utils.cfg:268
msgid "Born better than others, 5 more hitpoints + 3 more per level, 1 more damage per level, heals 2 HP every turn"
msgstr "Mieux né que les autres, 5 points de vie supplémentaires + 3 par niveau, 1 dégat de plus par niveau, guérit de 2 PV à chaque tour"

#. [object]
#: .\utils\item_list.cfg:9
msgid "Glitch Item"
msgstr "Objet Problème Technique"

#. [latent]
#: .\utils\item_list.cfg:14
msgid "<span color='red'>New obligation: Report this bug on the forums</span>"
msgstr "<span color='red'>Nouvelle obligation : Signaler ce bug sur les forums</span>"

#. [object]
#: .\utils\item_list.cfg:19
msgid "Everything can fail. Regardless of the amount of polishing done."
msgstr "Tout peut échouer. Quel que soit le degré de polissage effectué."

#. [object]
#: .\utils\item_list.cfg:22
msgid "Book of Magical Swordplay"
msgstr "Livre d'Épéisme Magique"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:32
msgid "Fencing techniques, offensive and also defensive"
msgstr "Techniques d'escrime, offensives et aussi défensives"

#. [object]
#: .\utils\item_list.cfg:34
msgid "It is not strength or motivation that makes a great warrior. It is the skill."
msgstr "Ce n'est pas la force ou la motivation qui fait un grand guerrier. C'est la compétence."

#. [object]
#: .\utils\item_list.cfg:37
msgid "Book of Fireballs"
msgstr "Livre des boules de feu"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:48
msgid "Casting fireballs, from basic casting to explosive damages"
msgstr "Lancer de boules de feu, du lancer de base aux dégâts explosifs"

#. [object]
#: .\utils\item_list.cfg:50
msgid "Burn, incinerate, scorch, see your foes turn to ash."
msgstr "Brûlez, incinérez, incendiez, voyez vos ennemis se transformer en cendres."

#. [object]
#: .\utils\item_list.cfg:53
msgid "Book of Herbal Tinctures and Malignancies"
msgstr "Livre de Teintures Végétales et de Malignités"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:63
msgid "Poisons and cures"
msgstr "Poisons et remèdes"

#. [object]
#: .\utils\item_list.cfg:65
msgid "Like real cures are not needed to get payment for healing, real poison is not needed to harm."
msgstr "De même qu'il n'est pas nécessaire d'avoir de vrais remèdes pour être payé pour la guérison, il n'est pas nécessaire d'avoir un vrai poison pour nuire."

#. [object]
#: .\utils\item_list.cfg:68
msgid "Tome of Bards"
msgstr "Tome des Bardes"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:78
msgid "Techniques of inspiring allies to deal more damage"
msgstr "Techniques pour inciter les alliés à infliger plus de dégâts"

#. [object]
#: .\utils\item_list.cfg:80
msgid ""
"Stand up and fight\n"
"Stand up and see the sky turn bright"
msgstr ""
"Lève-toi et bats-toi\n"
"Lève-toi et vois le ciel s'éclaircir"

#. [object]
#: .\utils\item_list.cfg:84
msgid "Warguard"
msgstr "Garde de Guerre"

#. [object]
#: .\utils\item_list.cfg:98
msgid "A real warrior's armour is heavy."
msgstr "L'armure d'un vrai guerrier est lourde. "

#. [object]
#: .\utils\item_list.cfg:101
msgid "The Fencer's Study"
msgstr "L'Étude du Bretteur"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:111
msgid "Quick mastery of fencing"
msgstr "Maîtrise Rapide de l'Escrime"

#. [object]
#: .\utils\item_list.cfg:113
msgid "Do you think fencing takes a lot of time to learn? Just buy this for 20 gold and see how easy it is!"
msgstr "Vous pensez que l'apprentissage de l'escrime prend beaucoup de temps ? Achetez ceci pour 20 pièces d'or et vous verrez comme c'est facile !"

#. [object]
#: .\utils\item_list.cfg:116
msgid "Iron Armour"
msgstr "Armure de Fer"

#. [object]
#: .\utils\item_list.cfg:128
msgid "When choosing between a hundred warriors clad in iron and fifty warriors clad in mithril, choose iron."
msgstr "Si vous avez le choix entre cent guerriers vêtus de fer et cinquante guerriers vêtus de mithril, choisissez le fer."

#. [object]
#: .\utils\item_list.cfg:131
msgid "Iron Armour of Thorns"
msgstr "Armure de Fer d'Épines"

#. [object]
#: .\utils\item_list.cfg:149
msgid "Do you think that you can attack me and leave uninjured?"
msgstr "Pensez-vous pouvoir m'attaquer et en sortir indemne ?"

#. [object]
#: .\utils\item_list.cfg:152
msgid "Mithral Armour"
msgstr "Armure en mithril"

#. [object]
#: .\utils\item_list.cfg:165
msgid "This highly valuable armour is told to be made by dwarvish apprentices. I wonder what their masters make."
msgstr "Cette armure de grande valeur est fabriquée par des apprentis nains. Je me demande ce que font leurs maîtres."

#. [object]
#: .\utils\item_list.cfg:168
msgid "Leather Armour"
msgstr "Armure de Cuir"

#. [object]
#: .\utils\item_list.cfg:176
msgid "I know that it is cheap, but it does not slow me down."
msgstr "Je sais que c'est bon marché, mais cela ne me ralentit pas."

#. [object]
#: .\utils\item_list.cfg:179
msgid "Ice Armour"
msgstr "Armure de Glace"

#. [object]
#: .\utils\item_list.cfg:188
msgid "Dwarvish runes can prevent ice from melting."
msgstr "Les runes naines peuvent empêcher la glace de fondre."

#. [object]
#: .\utils\item_list.cfg:191
msgid "Hellforge Armour"
msgstr "Armure de la Forge de l'Enfer"

#. [object]
#: .\utils\item_list.cfg:201
msgid "'Forge me an armour. I need to have forged armour to stop attacks armour stops.' - Abaddon"
msgstr "'Forgez-moi une armure. J'ai besoin d'une armure forgée pour arrêter les attaques qu'armure arrête.' - Abaddon"

#. [object]
#: .\utils\item_list.cfg:204
msgid "Mystic Armour"
msgstr "Armure Mystique"

#. [object]
#: .\utils\item_list.cfg:218
msgid "Forged at unknown location who knows when."
msgstr "Forgée en un lieu inconnu, on ne sait quand."

#. [object]
#: .\utils\item_list.cfg:221
msgid "Ring of Wizard's Bane"
msgstr "Anneau du Fléau du Sorcier"

#. [object]
#: .\utils\item_list.cfg:231
msgid "Nice fireworks, loser."
msgstr "Joli feu d'artifice, loser."

#. [object]
#: .\utils\item_list.cfg:234
msgid "Ring of Dragon's Bane"
msgstr "Anneau du Fléau du Dragon"

#. [object]
#: .\utils\item_list.cfg:243
msgid "Dragons are no challenge, let us hunt scorpions instead."
msgstr "Les dragons ne sont pas un défi, chassons plutôt les scorpions."

#. [object]
#: .\utils\item_list.cfg:246
#: .\utils\item_list.cfg:10047
msgid "Ring of Unearthly Existence"
msgstr "Anneau d'Existence d'Outremonde"

#. [object]
#: .\utils\item_list.cfg:258
#: .\utils\item_list.cfg:10060
msgid "Warriors were no match for him. He was no match for wizards."
msgstr "Les guerriers ne pouvaient rien contre lui. Il ne pouvait rien contre les sorciers."

#. [object]
#: .\utils\item_list.cfg:261
msgid "Ring of Iced Veins"
msgstr "Anneau de Veines Glacées"

#. [object]
#: .\utils\item_list.cfg:272
msgid ""
"'Your hand is colder than ice! Are you sure do not need warm tea?'\n"
"'No, I am fine, mom.'"
msgstr ""
"'Ta main est plus froide que la glace ! Tu es sûr de ne pas avoir besoin de thé chaud ?'\n"
"'Non, je vais bien, maman'."

#. [object]
#: .\utils\item_list.cfg:276
msgid "The Black Ring"
msgstr "L'Anneau Noir"

#. [object]
#: .\utils\item_list.cfg:288
msgid "There were two hundreds of us before the battle. Three hundreds of us left the battlefield."
msgstr "Nous étions deux cents avant la bataille. Trois cents d'entre nous ont quitté le champ de bataille."

#. [object]
#: .\utils\item_list.cfg:291
msgid "Ring of Deathaura"
msgstr "Anneau d'Aura de Mort"

#. [object]
#: .\utils\item_list.cfg:307
msgid "A harbinger of death from the world of witchcraft."
msgstr "Un annonciateur de mort issu du monde de la sorcellerie."

#. [object]
#: .\utils\item_list.cfg:310
msgid "Ring of Health"
msgstr "Anneau de Santé"

#. [object]
#: .\utils\item_list.cfg:329
msgid "Health is more important than body count."
msgstr "La santé est plus importante que le nombre de victimes."

#. [object]
#: .\utils\item_list.cfg:332
msgid "Nocturnal Cloak"
msgstr "Cape Nocturne"

#. [object]
#: .\utils\item_list.cfg:353
msgid "You merely adopted darkness, I was molded by it."
msgstr "Vous avez simplement adopté l'obscurité, j'ai été façonné par elle."

#. [object]
#: .\utils\item_list.cfg:356
msgid "Woodland Cloak"
msgstr "Cape des Bois"

#. [object]
#: .\utils\item_list.cfg:382
msgid "Where is the elf wearing that green cloak? Has anybody seen him?"
msgstr "Où est l'elfe qui porte cette cape verte ? Quelqu'un l'a-t-il vu ?"

#. [object]
#: .\utils\item_list.cfg:385
msgid "Cloak of Burning Retribution"
msgstr "Manteau de Rétribution Ardente"

#. [object]
#: .\utils\item_list.cfg:400
msgid "You spat on the ground at my feet? I will set your house on fire!"
msgstr "Tu as craché par terre à mes pieds ? Je vais mettre le feu à ta maison !"

#. [object]
#: .\utils\item_list.cfg:403
msgid "Flaming Sword"
msgstr "Épée Flamboyante"

#. [object]
#: .\utils\item_list.cfg:414
msgid "If you need to fight ghosts, good steel is not enough."
msgstr "Si vous devez combattre des fantômes, un bon acier ne suffit pas."

#. [object]
#: .\utils\item_list.cfg:417
msgid "Sword of Barys"
msgstr "Epée de Barys"

#. [object]
#: .\utils\item_list.cfg:431
msgid "A rare metal burns with green flame. Its ashes are poisonous, so be careful with it."
msgstr "Un métal rare brûle avec une flamme verte. Ses cendres sont toxiques, il faut donc s'en méfier."

#. [object]
#: .\utils\item_list.cfg:434
msgid "Holy Sword"
msgstr "Epée Sainte"

#. [object]
#: .\utils\item_list.cfg:455
msgid "Stay in my light and your sword shall destroy the servants of darkness."
msgstr "Restez dans ma lumière et votre épée détruira les servants des ténèbres."

#. [object]
#: .\utils\item_list.cfg:458
msgid "Dragon Claw"
msgstr "Griffe du Dragon"

#. [object]
#: .\utils\item_list.cfg:467
msgid "Claws of dragons have no unusual magical properties, but they cut so well."
msgstr "Les griffes de dragons n'ont pas de propriétés magiques particulières, mais elles coupent si bien."

#. [object]
#: .\utils\item_list.cfg:470
msgid "Claymore"
msgstr "Claymore"

#. [object]
#: .\utils\item_list.cfg:483
msgid "I am done with you, go away!"
msgstr "J'en ai fini avec vous, partez !"

#. [object]
#: .\utils\item_list.cfg:486
msgid "Deathbringer"
msgstr "Faiseur de Mort"

#. [object]
#: .\utils\item_list.cfg:500
msgid "Die! Die! Die! Wait... how do I make him die instead of simply getting cut?"
msgstr "Meurt ! Meurt ! Meurt ! Attendez... comment je le fais mourir et pas seulement être coupé ?"

#. [object]
#: .\utils\item_list.cfg:503
msgid "Silver Axe"
msgstr "Hache d'Argent"

#. [object]
#: .\utils\item_list.cfg:512
msgid "Good metal is better than flashy magic."
msgstr "Du bon métal vaut mieux que de la magie tape-à-l'œil."

#. [object]
#: .\utils\item_list.cfg:515
msgid "Axe of Perun"
msgstr "Hache de Perun"

#. [object]
#: .\utils\item_list.cfg:532
msgid "Perun's axe smote the wicked with thundering rage."
msgstr "La hache de Perun frappa les malfaisants avec une rage foudroyante."

#. [object]
#: .\utils\item_list.cfg:535
msgid "Unholy Axe"
msgstr "Hache Impie"

#. [object]
#: .\utils\item_list.cfg:557
msgid "You, comrade with that Unholy Axe, position yourself as far from me as possible!"
msgstr "Toi, camarade à la hache impie, place-toi le plus loin possible de moi !"

#. [object]
#: .\utils\item_list.cfg:560
msgid "Fine bow"
msgstr "Arc Fin"

#. [object]
#: .\utils\item_list.cfg:574
msgid "Precision is more important than anything else."
msgstr "La précision est plus importante que toute autre chose."

#. [object]
#: .\utils\item_list.cfg:577
#: .\utils\item_list.cfg:9979
msgid "Stormforce"
msgstr "Force-Tempête"

#. [object]
#: .\utils\item_list.cfg:591
#: .\utils\item_list.cfg:9994
msgid "Is that the fabled Stormforce? I thought it was just a legend!"
msgstr "Est-ce le légendaire Force-Tempête ? Je croyais que ce n'était qu'une légende !"

#. [object]
#: .\utils\item_list.cfg:594
msgid "Poisonous Bow"
msgstr "Arc Venimeux"

#. [object]
#: .\utils\item_list.cfg:606
msgid "Please stop focusing on one enemy."
msgstr "Cessez de vous focaliser sur un seul ennemi."

#. [object]
#: .\utils\item_list.cfg:609
msgid "Amulet of Reason"
msgstr "Amulette de Raison"

#. [object]
#: .\utils\item_list.cfg:619
msgid "The world is much better without magic."
msgstr "Le monde est bien meilleur sans magie."

#. [object]
#: .\utils\item_list.cfg:622
msgid "Frozen Locket"
msgstr "Médaillon Gelé"

#. [object]
#: .\utils\item_list.cfg:636
msgid "Frozen memories shall thaw and redeem."
msgstr "Les souvenirs gelés seront décongelés et restaurés."

#. [object]
#: .\utils\item_list.cfg:639
msgid "Black Widow"
msgstr "Veuve Noire"

#. [object]
#: .\utils\item_list.cfg:657
msgid "That horrid thing corrupts the very air around us!"
msgstr "Cette horrible chose corrompt l'air qui nous entoure !"

#. [object]
#: .\utils\item_list.cfg:660
#: .\utils\item_list.cfg:10063
msgid "Staff of Crelanu"
msgstr "Bâton de Crelanu"

#. [object]
#: .\utils\item_list.cfg:669
#: .\utils\item_list.cfg:10073
msgid "Crelanu's staff fell into the wrong hands before it was even made."
msgstr "Le bâton de Crelanu est tombé entre de mauvaises mains avant même d'avoir été fabriqué."

#. [object]
#: .\utils\item_list.cfg:672
msgid "Staff of Kerathur"
msgstr "Bâton de Kerathur"

#. [object]
#: .\utils\item_list.cfg:685
msgid "'I know that you have no idea who I am...' - Kerathur the Unheard Of"
msgstr "'Je sais que vous n'avez aucune idée de qui je suis...' - Kerathur L'Inédit"

#. [object]
#: .\utils\item_list.cfg:688
msgid "Staff of Aimucasur"
msgstr "Bâton d'Aimucasur"

#. [object]
#: .\utils\item_list.cfg:701
msgid "A skeletal horde rose from the mud to take lives away. Konrad's warriors were too strong for them."
msgstr "Une horde de squelettes surgit de la boue pour faucher des vies. Les guerriers de Konrad étaient trop forts pour eux."

#. [object]
#: .\utils\item_list.cfg:704
msgid "Staff of Koschei"
msgstr "Bâton de Koschei"

#. [latent]
#: .\utils\item_list.cfg:717
msgid "<span color='purple'>16 to Maximum Health (requires Koschei's Journal)</span>"
msgstr "<span color='purple'>16 au maximum de PV (nécessite Journal de Koschei)</span>"

#. [object]
#: .\utils\item_list.cfg:722
msgid "Koschei kidnapped a young princess. His mundane motivations caused his fall."
msgstr "Koschei a enlevé une jeune princesse. Ses motivations banales ont causé sa chute."

#. [object]
#: .\utils\item_list.cfg:725
msgid "Staff of Circe"
msgstr "Bâton de Circé"

#. [object]
#: .\utils\item_list.cfg:737
msgid "Eurylochus knew he could not trust her. It saved his life."
msgstr "Euryloque savait qu'il ne pouvait pas lui faire confiance. Cela lui a sauvé la vie."

#. [object]
#: .\utils\item_list.cfg:740
msgid "Poison"
msgstr "Poison"

#. [object]
#: .\utils\item_list.cfg:742
msgid "<span color='orange'>New weapon special: Poison</span>"
msgstr "<span color='orange'>Nouvelle spécialité d'attaque : Poison</span>"

#. [object]
#: .\utils\item_list.cfg:765
msgid "Why is this technique a taboo?"
msgstr "Pourquoi cette technique est-elle taboue ?"

#. [object]
#: .\utils\item_list.cfg:768
msgid "Healing Potion"
msgstr "Potion de Guérison"

#. [object]
#: .\utils\item_list.cfg:770
msgid "<span color='orange'>This unit is fully healed, and its total HP is increased by 10.</span>"
msgstr "<span color='orange'>Cette unité est entièrement soignée et son total de PV est augmenté de 10.</span>"

#. [object]
#: .\utils\item_list.cfg:784
msgid "I am healed! More healthy than ever!"
msgstr "Je suis guéri ! Plus sain que jamais !"

#. [object]
#: .\utils\item_list.cfg:787
msgid "Foul Potion"
msgstr "Potion Infecte"

#. [object]
#: .\utils\item_list.cfg:789
msgid "<span color='orange'>New ability: Unholy hunger (the unit loses increasing amounts of maximum HP per turn (unless cared by a healer), but when it kills an enemy, the count restarts and it gains 3 to maximum HP and is healed slightly).  Has no effect if the victim cannot be drained, like the undead.</span>"
msgstr "<span color='orange'>Nouvelle capacité : Faim Impie (l'unité perd de plus en plus de PV maximum à chaque tour (à moins d'être soignée par un guérisseur), mais lorsqu'elle tue un ennemi, le compte recommence et elle gagne 3 PV maximum et est légèrement soignée). N'a aucun effet si la vicitime ne peut pas être drainée, comme un mort-vivant.</span>"

#. [object]
#: .\utils\item_list.cfg:804
msgid "It helps us greatly, but its user pays a great price."
msgstr "C'est une aide précieuse, mais son utilisateur en paie le prix fort."

#. [object]
#: .\utils\item_list.cfg:807
msgid "Holy potion"
msgstr "Potion Sacrée"

#. [object]
#: .\utils\item_list.cfg:809
msgid "<span color='orange'>This unit will do triple damages to undead, black souls, demons and burning souls in melee combat.</span>"
msgstr "<span color='orange'>Cette unité inflige trois fois plus de dégâts aux morts-vivants, aux âmes noires, aux démons et aux âmes brûlantes en combat de mêlée.</span>"

#. [object]
#: .\utils\item_list.cfg:823
msgid "Grrrh! Remove this filth from this world! Rrrargh!"
msgstr "Grrrh ! Retirez cette saleté de ce monde ! Rrrargh !"

#. [object]
#: .\utils\item_list.cfg:826
msgid "Potion of Speed"
msgstr "Potion de Vitesse"

#. [object]
#: .\utils\item_list.cfg:828
msgid ""
"<span color='orange'>1 more attack\n"
"2 more movement points</span>"
msgstr ""
"<span color='orange'>1 attaque supplémentaire\n"
"2 points de mouvement supplémentaires</span>"

#. [object]
#: .\utils\item_list.cfg:843
msgid "The quickest, the fastest, born under the sonic sign."
msgstr "Le plus rapide, le plus véloce, né sous le signe sonique."

#. [object]
#: .\utils\item_list.cfg:846
msgid "Spirits of a Madman's Alacrity"
msgstr "Esprits de l'Alacrité d'un Fou"

#. [object]
#: .\utils\item_list.cfg:848
msgid "<span color='orange'>1 extra attack per turn</span>"
msgstr "<span color='orange'>1 attaque supplémentaire par tour</span>"

#. [object]
#: .\utils\item_list.cfg:857
msgid "Are you sane? You cannot fight so much, we will run out of enemies too soon!"
msgstr "Êtes-vous sains d'esprit ? Vous ne pouvez pas vous battre autant, nous allons bientôt manquer d'ennemis !"

#. [object]
#: .\utils\item_list.cfg:860
msgid "Headstriker"
msgstr "Tête Chercheuse"

#. [object]
#: .\utils\item_list.cfg:873
msgid "If you have a good aim, you will hit a vulnerable spot and kill even with a lightweight bolt."
msgstr "Si vous visez bien, vous atteindrez un point vulnérable et vous tuerez même avec un carreau léger."

#. [object]
#: .\utils\item_list.cfg:876
msgid "Chu-ko-nu"
msgstr "Chu-ko-nu"

#. [object]
#: .\utils\item_list.cfg:889
msgid "Do you even reload that thing?"
msgstr "Est-ce qu'au moins vous rechargez ce truc ?"

#. [object]
#: .\utils\item_list.cfg:892
#: .\utils\item_list.cfg:10076
msgid "Ballista"
msgstr "Baliste"

#. [object]
#: .\utils\item_list.cfg:900
#: .\utils\item_list.cfg:10085
msgid "Are you sure that thing is meant to be hand-held?"
msgstr "Êtes-vous sûr que cette chose est destinée à être tenue à la main ?"

#. [object]
#: .\utils\item_list.cfg:903
msgid "Doomsday Machine"
msgstr "Machine de Fin du Monde"

#. [object]
#: .\utils\item_list.cfg:919
msgid "To spread doom, you need proper tools."
msgstr "Pour répandre le malheur, il faut des outils adéquats."

#. [object]
#: .\utils\item_list.cfg:922
msgid "Nightstalker"
msgstr "Chasseur Nocturne"

#. [object]
#: .\utils\item_list.cfg:938
msgid "That looming darkness is a herald of his arrival. Somebody will die very soon."
msgstr "Cette obscurité imminente est le signe annonciateur de son arrivée. Quelqu'un va mourir très bientôt."

#. [object]
#: .\utils\item_list.cfg:941
msgid "Dagger of Shielding"
msgstr "Dague de Blindage"

#. [object]
#: .\utils\item_list.cfg:954
msgid "He survived a thousand knife fights. Not because of his bravery."
msgstr "Il a survécu à un millier de combats au couteau. Pas grâce à sa bravoure."

#. [object]
#: .\utils\item_list.cfg:957
msgid "Dagger of Sicarii"
msgstr "Dague de Sicarii"

#. [object]
#: .\utils\item_list.cfg:980
msgid "An oppressed nation will find a way to have its revenge."
msgstr "Une nation opprimée trouvera un moyen de se venger."

#. [object]
#: .\utils\item_list.cfg:983
msgid "Spineripper"
msgstr "Arracheur Dorsal"

#. [object]
#: .\utils\item_list.cfg:996
msgid "Look at that exposed back."
msgstr "Regardez ce dos exposé."

#. [object]
#: .\utils\item_list.cfg:999
msgid "The Vile Knife"
msgstr "Le Vil Couteau"

#. [object]
#: .\utils\item_list.cfg:1015
msgid "Wounds heal, poison remains."
msgstr "Les blessures guérissent, mais le poison demeure."

#. [object]
#: .\utils\item_list.cfg:1018
msgid "Steel Helmet"
msgstr "Casque en Acier"

#. [object]
#: .\utils\item_list.cfg:1029
msgid ""
"'What is this thing good for?'\n"
"'Nothing special.'"
msgstr ""
"'À quoi sert ce truc ?'\n"
"'Rien de spécial'."

#. [object]
#: .\utils\item_list.cfg:1033
msgid "Helmet of Paladins"
msgstr "Casque des Paladins"

#. [object]
#: .\utils\item_list.cfg:1047
msgid "Let the light show you the way into the darkness that you can enlighten."
msgstr "Laissez la lumière vous montrer le chemin vers les ténèbres que vous pouvez éclairer."

#. [object]
#: .\utils\item_list.cfg:1050
msgid "Royal Diadem"
msgstr "Diadème Royal"

#. [leadership], id=royalty
#: .\utils\item_list.cfg:1064
msgid "royalty"
msgstr "royauté"

#. [leadership], id=royalty
#: .\utils\item_list.cfg:1065
msgid "female^royalty"
msgstr "royauté"

#. [leadership], id=royalty
#: .\utils\item_list.cfg:1066
msgid ""
"This unit can lead your own units that are next to it, making them fight better.\n"
"\n"
"Adjacent own units will do 30% more damage and will have 20% better resistances."
msgstr ""
"Cette unité peut commander à vos propres unités qui se trouvent à côté d'elle, ce qui leur permet de mieux se battre.\n"
"\n"
"Les unités propres adjacentes feront 30 % de dégâts en plus et auront 20 % de résistances en plus."

#. [object]
#: .\utils\item_list.cfg:1093
msgid "Even a fake king can lead soldiers into victory."
msgstr "Même un faux roi peut mener des soldats à la victoire."

#. [object]
#: .\utils\item_list.cfg:1096
msgid "Irongut Helmet"
msgstr "Casque de Courage de Fer"

#. [object]
#: .\utils\item_list.cfg:1110
msgid ""
"'Are those berries edible?'\n"
"'Who cares?'"
msgstr ""
"'Ces baies sont-elles comestibles ?'\n"
"'Qui s'en soucie ?'"

#. [object]
#: .\utils\item_list.cfg:1114
msgid "Mighty Gauntlets"
msgstr "Gantelets Puissants"

#. [object]
#: .\utils\item_list.cfg:1125
msgid "Like any other visitor, he put his sword on a rack outside. His mighty fists were deadly enough."
msgstr "Comme tout autre visiteur, il pose son épée sur un support à l'extérieur. Ses poings puissants sont suffisamment meurtriers."

#. [object]
#: .\utils\item_list.cfg:1128
msgid "Quick Gauntlets"
msgstr "Gantelets Rapides"

#. [object]
#: .\utils\item_list.cfg:1138
msgid "Quick hands are the best defence."
msgstr "Des mains rapides sont la meilleure défense."

#. [object]
#: .\utils\item_list.cfg:1141
msgid "Heavy Gauntlets"
msgstr "Gantelets Lourds"

#. [object]
#: .\utils\item_list.cfg:1152
msgid "How the hell do you fight with this?"
msgstr "Comment peut-on lutter contre cela ?"

#. [object]
#: .\utils\item_list.cfg:1155
msgid "Hellslash"
msgstr "Slash de l'Enfer"

#. [object]
#: .\utils\item_list.cfg:1168
msgid "Careful about him, you will get hurt even if he is not attacking you."
msgstr "Attention à lui, vous risquez d'être blessé même s'il ne vous attaque pas."

#. [object]
#: .\utils\item_list.cfg:1171
msgid "Wanderlust"
msgstr "Désir de Voyage"

#. [object]
#: .\utils\item_list.cfg:1184
msgid "See far. Go far. Know the beauty of the world."
msgstr "Voir loin. Aller loin. Connaître la beauté du monde."

#. [object]
#: .\utils\item_list.cfg:1187
msgid "Flying Boots"
msgstr "Bottes Volantes"

#. [object]
#: .\utils\item_list.cfg:1216
msgid "He could run through caves and hills like on a plain road. He could even walk on water."
msgstr "Il pouvait courir à travers des grottes et des collines comme sur une route ordinaire. Il pouvait même marcher sur l'eau."

#. [object]
#: .\utils\item_list.cfg:1219
msgid "Slow Boots"
msgstr "Bottes Lentes"

#. [object]
#: .\utils\item_list.cfg:1232
msgid "If you cannot outrun the knights, why do you even try?"
msgstr "Si vous ne pouvez pas distancer les chevaliers, pourquoi essayer ?"

#. [object]
#: .\utils\item_list.cfg:1235
msgid "Boots of Evanescence"
msgstr "Bottes d'Évanescence"

#. [object]
#: .\utils\item_list.cfg:1259
msgid "Now you see me. Now you don't."
msgstr "Là, tu me vois. Là, tu ne me vois plus."

#. [object]
#: .\utils\item_list.cfg:1262
msgid "Heathenbasher"
msgstr "Basheur de Païens"

#. [object]
#: .\utils\item_list.cfg:1282
msgid "Dark is the night that has set to your mind, sweet is the pride that reflects in your eyes."
msgstr "Sombre est la nuit qui s'est installée dans ton esprit, douce est la fierté qui se reflète dans tes yeux."

#. [object]
#: .\utils\item_list.cfg:1285
msgid "Tormentor of Light"
msgstr "Tourmenteur de Lumière"

#. [object]
#: .\utils\item_list.cfg:1303
msgid "In the absence of light, darkness and disorder rules."
msgstr "En l'absence de lumière, l'obscurité et le désordre règnent."

#. [object]
#: .\utils\item_list.cfg:1306
msgid "Morgenstern"
msgstr "Morgenstern"

#. [object]
#: .\utils\item_list.cfg:1324
msgid "The star of dawn will smash your face."
msgstr "L'étoile de l'aube vous écrasera le visage."

#. [object]
#: .\utils\item_list.cfg:1327
#: .\utils\item_list.cfg:10088
msgid "Wrath of the Pagan"
msgstr "Courroux du Païen"

#. [object]
#: .\utils\item_list.cfg:1340
#: .\utils\item_list.cfg:10102
msgid "Law or chaos? That is just a point of view not everyone shares."
msgstr "Loi ou chaos ? C'est un point de vue que tout le monde ne partage pas."

#. [object]
#: .\utils\item_list.cfg:1343
msgid "Blackened Cloak"
msgstr "Manteau Noirci"

#. [object]
#: .\utils\item_list.cfg:1358
msgid "Under black skies, people start losing faith that the sun will ever rise."
msgstr "Sous des cieux noirs, les gens commencent à perdre la foi que le soleil se lèvera un jour."

#. [object]
#: .\utils\item_list.cfg:1361
msgid "Colossally Colossal Arch-Devilish Blade of Universal Annihilation"
msgstr "Lame Colossalement Colossale Archi-Démoniaque d'Annihilation Universelle"

#. [leadership], id=aura of power
#: .\utils\item_list.cfg:1379
msgid "aura of universal annihilation"
msgstr "aura d'annihilation universelle"

#. [leadership], id=aura of power
#: .\utils\item_list.cfg:1380
msgid "female^aura of universal annihilation"
msgstr "aura d'annihilation universelle"

#. [leadership], id=aura of power
#: .\utils\item_list.cfg:1381
msgid ""
"This unit can lead your own units that are next to it, making them fight better.\n"
"\n"
"Adjacent own units will do 20% more damage and will have 10% better resistances."
msgstr ""
"Cette unité peut commander vos propres unités qui se trouvent à côté d'elle, ce qui leur permet de mieux se battre.\n"
"\n"
"Les unités propres adjacentes feront 20 % de dégâts en plus et auront 10 % de résistances en plus."

#. [object]
#: .\utils\item_list.cfg:1407
msgid "Forged by the Paladin of Golden Glory with the Hammer of Eternal Magic."
msgstr "Forgée par le Paladin de la Gloire Dorée avec le Marteau de la Magie Éternelle."

#. [object]
#: .\utils\item_list.cfg:1410
msgid "Mask of Insanity"
msgstr "Masque de la Folie"

#. [object]
#: .\utils\item_list.cfg:1423
msgid "Insanity allows doing things that could not be done otherwise, but at a great cost."
msgstr "La folie permet de faire des choses que l'on ne pourrait pas faire autrement, mais à un prix élevé."

#. [object]
#: .\utils\item_list.cfg:1426
msgid "Hell Warlord's Armour"
msgstr "Armure du Seigneur de Guerre de l'Enfer"

#. [object]
#: .\utils\item_list.cfg:1443
msgid "Abaddon ruled Inferno with an iron hand, but it did not stop his loyals from following him."
msgstr "Abaddon dirige Inferno d'une main de fer, mais cela n'empêche pas ses fidèles de le suivre."

#. [object]
#: .\utils\item_list.cfg:1446
msgid "Demon Core"
msgstr "Demon Core"

#. [object]
#: .\utils\item_list.cfg:1466
msgid "If you awaken it, foul light will ravage flesh."
msgstr "Si vous le réveillez, une lumière nauséabonde ravagera les chairs."

#. [object]
#: .\utils\item_list.cfg:1469
msgid "Zealous Axe"
msgstr "Hache Zélée"

#. [object]
#: .\utils\item_list.cfg:1488
msgid "Let them try to attack us for we shall be those who strike first."
msgstr "Qu'ils essaient de nous attaquer, car nous serons les premiers à frapper."

#. [object]
#: .\utils\item_list.cfg:1491
msgid "Cloak of the Assassin leader"
msgstr "Manteau du Chef des Assassins"

#. [object]
#: .\utils\item_list.cfg:1510
msgid "I care not if you are assassins or not, when you are around me, you will attack my way."
msgstr "Je me fiche que vous soyez des assassins ou non, quand vous serez près de moi, vous attaquerez à ma façon."

#. [object]
#: .\utils\item_list.cfg:1513
msgid "Bow of the Cantor"
msgstr "Arc du Cantor"

#. [object]
#: .\utils\item_list.cfg:1531
msgid "Now I shall teach you how to hit the bull's eye. Stay close while I am talking."
msgstr "Je vais maintenant vous apprendre à faire mouche. Reste près de moi pendant que je parle."

#. [object]
#: .\utils\item_list.cfg:1534
msgid "Amulet of Twilight"
msgstr "Amulette du Crépuscule"

#. [object]
#: .\utils\item_list.cfg:1548
msgid "When the day and night mix, unique powers appear."
msgstr "Lorsque le jour et la nuit se mélangent, des pouvoirs uniques apparaissent."

#. [object]
#: .\utils\item_list.cfg:1551
msgid "Dagger of Craving"
msgstr "Poignard de Désir"

#. [object]
#: .\utils\item_list.cfg:1565
msgid "Does this make you feel some sort of... bloodlust?"
msgstr "Cela vous donne-t-il une sorte de... soif de sang ?"

#. [object]
#: .\utils\item_list.cfg:1568
msgid "Book of Courage"
msgstr "Livre du Courage"

#. [object]
#: .\utils\item_list.cfg:1570
msgid "<span color='green'>Unit becomes fearless</span>"
msgstr "<span color='green'>L'unité devient intrépide</span>"

#. [value]
#: .\utils\item_list.cfg:1582
msgid "fearless"
msgstr "intrépide"

#. [value]
#: .\utils\item_list.cfg:1583
msgid "female^fearless"
msgstr "intrépide"

#. [value]
#: .\utils\item_list.cfg:1584
msgid "Fights normally during unfavourable times of day/night"
msgstr "Combat normalement pendant les périodes défavorables du jour ou de la nuit"

#. [object]
#: .\utils\item_list.cfg:1591
msgid "Daniel was looking for this book. But it was in a dark corner."
msgstr "Daniel cherchait ce livre. Mais il était dans un coin sombre."

#. [object]
#: .\utils\item_list.cfg:1594
msgid "Executioner's Axe"
msgstr "Hache du Bourreau"

#. [object]
#: .\utils\item_list.cfg:1607
msgid "A good executioner kills with a single blow."
msgstr "Un bon bourreau tue d'un seul coup."

#. [object]
#: .\utils\item_list.cfg:1610
msgid "The Impaler"
msgstr "L'Empaleur"

#. [object]
#: .\utils\item_list.cfg:1623
msgid "Do not hide behind your comrades, just run away."
msgstr "Ne vous cachez pas derrière vos camarades, fuyez."

#. [object]
#: .\utils\item_list.cfg:1626
msgid "Explosionlance"
msgstr "Lance Explosive"

#. [object]
#: .\utils\item_list.cfg:1638
msgid "Take that away, we need to stay silent."
msgstr "Si on nous enlève cela, nous devons rester silencieux."

#. [object]
#: .\utils\item_list.cfg:1641
msgid "Wicked Spear of Cruelty"
msgstr "Lance Diabolique de Cruauté"

#. [object]
#: .\utils\item_list.cfg:1655
msgid "With horror, he realised that the horse under him had joined the walking dead."
msgstr "Avec horreur, il s'aperçoit que le cheval sous lui a rejoint les morts-vivants."

#. [object]
#: .\utils\item_list.cfg:1658
msgid "The Original Trident of Storms"
msgstr "Le Trident Original des Tempêtes"

#. [effect], apply_to=new_attack, type=fire, range=ranged
#: .\utils\item_list.cfg:1673
msgid "storm trident"
msgstr "trident de tempête"

#. [object]
#: .\utils\item_list.cfg:1687
msgid "This is no obvious fake. Is it the true one or just a better fake?"
msgstr "Ce n'est pas un faux évident. S'agit-il du vrai ou d'un meilleur faux ?"

#. [object]
#: .\utils\item_list.cfg:1690
msgid "Lightbringer's Trident"
msgstr "Trident de Lightbringer"

#. [object]
#: .\utils\item_list.cfg:1705
msgid "He brought light, but it was red and searing."
msgstr "Il a apporté de la lumière, mais elle était rouge et brûlante."

#. [object]
#: .\utils\item_list.cfg:1708
#: .\utils\item_list.cfg:1710
msgid "200 gold"
msgstr "200 pièces d'or"

#. [object]
#: .\utils\item_list.cfg:1717
msgid "Money will not buy you anything. It is you who has to buy it for money."
msgstr "L'argent ne vous achètera rien. C'est vous qui devez l'acheter pour de l'argent."

#. [object]
#: .\utils\item_list.cfg:1720
#: .\utils\item_list.cfg:1722
msgid "100 gold"
msgstr "100 pièces d'or"

#. [object]
#: .\utils\item_list.cfg:1729
msgid "Why conquer when you can buy?"
msgstr "Pourquoi conquérir quand on peut acheter ?"

#. [object]
#: .\utils\item_list.cfg:1732
#: .\utils\item_list.cfg:1734
msgid "50 gold"
msgstr "50 pièces d'or"

#. [object]
#: .\utils\item_list.cfg:1741
msgid "Money is more powerful than magic."
msgstr "L'argent est plus puissant que la magie."

#. [object]
#: .\utils\item_list.cfg:1744
msgid "Dazzling Ring"
msgstr "Bague Éblouissante"

#. [object]
#: .\utils\item_list.cfg:1756
msgid "You were born to die blind."
msgstr "Tu es né pour mourir aveugle."

#. [object]
#: .\utils\item_list.cfg:1759
msgid "Boots of Fleeing"
msgstr "Bottes de Fuite"

#. [object]
#: .\utils\item_list.cfg:1773
msgid "I hit you and hide in the masses. You will never learn who hit you."
msgstr "Je te frappe et je me cache dans la masse. Vous ne saurez jamais qui vous a frappé."

#. [object]
#: .\utils\item_list.cfg:1776
msgid "Elusive Boots"
msgstr "Bottes Insaisissables"

#. [object]
#: .\utils\item_list.cfg:1791
msgid "Enemies are blocking the way? Who cares?"
msgstr "Des ennemis bloquent le chemin ? Qui s'en soucie ?"

#. [object]
#: .\utils\item_list.cfg:1794
msgid "Heavy Bow"
msgstr "Arc Lourd"

#. [object]
#: .\utils\item_list.cfg:1808
msgid "Fellows, what would you say if I made a bow that shoots spears?"
msgstr "Messieurs, que diriez-vous si je fabriquais un arc qui tire des lances ?"

#. [object]
#: .\utils\item_list.cfg:1811
msgid "Cunctator's sword"
msgstr "Épée de Cunctator"

#. [latent]
#: .\utils\item_list.cfg:1827
msgid "<span color='purple'>New melee weapon special: struggle (requires Cunctator's Armour)</span>"
msgstr "<span color='purple'>Nouvelle spécialité d'attaque de mêlée : lutte (nécessite Armure de Cunctator)</span>"

#. [latent]
#: .\utils\item_list.cfg:1837
msgid "<span color='purple'>5% to all magical resistances (requires Cunctator's Helmet)</span>"
msgstr "<span color='purple'>5 % à toutes les résistances magiques (nécessite Casque de Cunctator)</span>"

#. [object]
#: .\utils\item_list.cfg:1847
msgid "Nobody wanted to face Cunctator. He never fought when you wanted to fight him."
msgstr "Personne ne voulait affronter Cunctator. Il ne s'est jamais battu quand on voulait le combattre."

#. [object]
#: .\utils\item_list.cfg:1850
msgid "Guide to Lycanthropy"
msgstr "Guide de la Lycanthropie"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:1860
msgid "Abilities that allow a transformation into powerful animal forms"
msgstr "Capacités permettant de se transformer en de puissantes formes animales"

#. [object]
#: .\utils\item_list.cfg:1862
msgid "Search your memories and find the monster you are."
msgstr "Cherchez dans vos souvenirs et trouvez le monstre que vous êtes."

#. [object]
#: .\utils\item_list.cfg:1865
msgid "Tome of Bards, Volume II"
msgstr "Tome des Bardes, Volume II"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:1875
msgid "Techniques of inspiring allies to fight better and annoying enemies"
msgstr "Techniques permettant d'inciter les alliés à mieux se battre et d'ennuyer les ennemis"

#. [object]
#: .\utils\item_list.cfg:1877
msgid ""
"Shining and so glorious\n"
"The bloodline of true warriors"
msgstr ""
"Brillant et si glorieux\n"
"La lignée des vrais guerriers"

#. [object]
#: .\utils\item_list.cfg:1881
msgid "Koschei's Journal"
msgstr "Journal de Koschei"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:1891
msgid "Powerful improvements to spells"
msgstr "Améliorations puissantes des sorts"

#. [object]
#: .\utils\item_list.cfg:1893
msgid "The princess asked him where his soul was hidden. The prince found it."
msgstr "La princesse lui demanda où était cachée son âme. Le prince la trouva."

#. [object]
#: .\utils\item_list.cfg:1896
msgid "Wrathful Combat Techniques"
msgstr "Techniques de Combat Courroucé"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:1906
msgid "Techniques of using anger in battle"
msgstr "Techniques d'utilisation de la colère dans la bataille"

#. [object]
#: .\utils\item_list.cfg:1908
msgid "Let the anger flow through your veins."
msgstr "Laissez la colère couler dans vos veines."

#. [object]
#: .\utils\item_list.cfg:1911
msgid "How to be an Overlord"
msgstr "Comment être un Suzerain"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:1921
msgid "Leadership-like abilities"
msgstr "Capacités de Commandement"

#. [object]
#: .\utils\item_list.cfg:1923
msgid "Attack! Attack! Attack!"
msgstr "Attaquez ! Attaquez ! Attaquez !"

#. [object]
#: .\utils\item_list.cfg:1926
msgid "Greater Healing Potion"
msgstr "Grande Potion de Soin"

#. [object]
#: .\utils\item_list.cfg:1928
msgid "<span color='orange'>This unit is completely restored, including statuses, moves and attacks.</span>"
msgstr "<span color='orange'>Cette unité est complètement restaurée, y compris les statuts, les mouvements et les attaques.</span>"

#. [object]
#: .\utils\item_list.cfg:1940
msgid "This can heal almost anyone, find the one who brewed it!"
msgstr "Ce produit peut guérir presque tout le monde, trouvez celui qui l'a brassé !"

#. [object]
#: .\utils\item_list.cfg:1943
msgid "Deathwhirl"
msgstr "Tourbillon de la Mort"

#. [object]
#: .\utils\item_list.cfg:1963
msgid "Swarm him so that he would not get to me! Oh, dammit..."
msgstr "Assaillez-le pour qu'il ne m'atteigne pas ! Oh, bon sang..."

#. [object]
#: .\utils\item_list.cfg:1966
#: .\utils\item_list.cfg:10105
msgid "Glowing Flight"
msgstr "Vol Incandescent"

#. [object]
#: .\utils\item_list.cfg:1975
#: .\utils\item_list.cfg:10115
msgid "The pragmatic baron sent an assassin to kill a necromancer. It was not a bad idea."
msgstr "Le baron pragmatique a envoyé un assassin pour tuer un nécromancien. Ce n'était pas une mauvaise idée."

#. [object]
#: .\utils\item_list.cfg:1978
msgid "Headsmasher"
msgstr "Briseuse de Têtes"

#. [object]
#: .\utils\item_list.cfg:1989
msgid ""
"'Let us give the orcs something they like, maybe they will let us be.'\n"
"'What do they like?'\n"
"'Smashing heads.'"
msgstr ""
"'Donnons aux orcs quelque chose qu'ils aiment, peut-être qu'ils nous laisseront tranquilles'.\n"
"'Qu'est-ce qu'ils aiment ?'\n"
"'Défoncer des têtes.'"

#. [object]
#: .\utils\item_list.cfg:1994
msgid "Virtue of Hope"
msgstr "Vertu de l'Espoir"

#. [object]
#: .\utils\item_list.cfg:2009
msgid "See the ones who know."
msgstr "Voyez ceux qui savent."

#. [object]
#: .\utils\item_list.cfg:2012
msgid "Ice Armour of Health"
msgstr "Armure de Glace de Santé"

#. [object]
#: .\utils\item_list.cfg:2026
msgid "Hot weather is bad for health."
msgstr "La chaleur est mauvaise pour la santé."

#. [object]
#: .\utils\item_list.cfg:2029
msgid "Dragonslayer"
msgstr "Tueur de Dragons"

#. [object]
#: .\utils\item_list.cfg:2044
msgid "He killed dragons with his legendary bow, but he was no match for saurians."
msgstr "Il tuait les dragons avec son arc légendaire, mais il n'était pas de taille face aux sauriens."

#. [object]
#: .\utils\item_list.cfg:2047
msgid "Rherraent's Sword"
msgstr "Épée de Rherraent"

#. [latent]
#: .\utils\item_list.cfg:2061
msgid "<span color='purple'>+2 to base melee damage (requires Rherraent's Armour)</span>"
msgstr "<span color='purple'>+2 aux dégâts de base en mêlée (nécessite Armure de Rherraent)</span>"

#. [latent]
#: .\utils\item_list.cfg:2068
msgid "<span color='purple'>+2 to base melee damage (requires Rherraent's Helm)</span>"
msgstr "<span color='purple'>+2 aux dégâts de base en mêlée (nécessite Heaume de Rherraent)</span>"

#. [latent]
#: .\utils\item_list.cfg:2075
msgid "<span color='purple'>+2 to base melee damage (requires Rherraent's Ring)</span>"
msgstr "<span color='purple'>+2 aux dégâts de base en mêlée (nécessite Anneau de Rherraent)</span>"

#. [object]
#: .\utils\item_list.cfg:2081
msgid "In his hands, the sword was a formidable weapon. In the hands of its thief, it was useless."
msgstr "Dans ses mains, l'épée était une arme redoutable. Dans les mains de son voleur, elle était inutile."

#. [object]
#: .\utils\item_list.cfg:2084
msgid "Rherraent's Armour"
msgstr "Armure de Rherraent"

#. [latent]
#: .\utils\item_list.cfg:2097
#: .\utils\item_list.cfg:2143
msgid "<span color='purple'>1 more movement point (requires Rherraent's Sword)</span>"
msgstr "<span color='purple'>1 point de mouvement supplémentaire (nécessite Épée de Rherraent)</span>"

#. [latent]
#: .\utils\item_list.cfg:2103
msgid "<span color='purple'>3% to all resistances (requires Rherraent's Helm)</span>"
msgstr "<span color='purple'>3 % à toutes les résistances (nécessite Heaume de Rherraent)</span>"

#. [latent]
#: .\utils\item_list.cfg:2117
msgid "<span color='purple'>3% to all resistances (requires Rherraent's Ring)</span>"
msgstr "<span color='purple'>3 % à toutes les résistances (nécessite Anneau de Rherraent)</span>"

#. [object]
#: .\utils\item_list.cfg:2130
msgid "Shiny armour will only attract unwanted attention."
msgstr "Une armure brillante ne peut qu'attirer l'attention."

#. [object]
#: .\utils\item_list.cfg:2133
msgid "Rherraent's Helm"
msgstr "Heaume de Rherraent"

#. [latent]
#: .\utils\item_list.cfg:2149
msgid "<span color='purple'>12 more hitpoints (requires Rherraent's Armour)</span>"
msgstr "<span color='purple'>12 points de vie supplémentaires (nécessite Armure de Rherraent)</span>"

#. [latent]
#: .\utils\item_list.cfg:2155
msgid "<span color='purple'>12 more hitpoints (requires Rherraent's Ring)</span>"
msgstr "<span color='purple'>12 points de vie supplémentaires (nécessite Anneau de Rherraent)</span>"

#. [object]
#: .\utils\item_list.cfg:2160
msgid ""
"Look at your foes face to face,\n"
"defeat your foes mace to face."
msgstr ""
"Regardez vos ennemis face à face,\n"
"vainquez vos ennemis masse à face."

