msgstr "<span color='purple'>+1 aux attaques de base (nécessite Anneau de l'Exterminateur)</span>"

#. [object]
#: .\utils\item_list.cfg:2295
#: .\utils\item_list.cfg:9890
msgid "It may be hard to get close enough."
msgstr "Il peut être difficile de s'approcher suffisamment."

#. [object]
#: .\utils\item_list.cfg:2298
#: .\utils\item_list.cfg:9893
msgid "Exterminator's Ring"
msgstr "Anneau de l'Exterminateur"

#. [latent]
#: .\utils\item_list.cfg:2313
#: .\utils\item_list.cfg:9909
msgid "<span color='purple'>+1 to base ranged damage (requires Exterminator's Dagger)</span>"
msgstr "<span color='purple'>+1 aux dégâts de base à distance (nécessite Dague de l'Exterminateur)</span>"

#. [object]
#: .\utils\item_list.cfg:2333
#: .\utils\item_list.cfg:9929
msgid "Hide from the revolution."
msgstr "Cachez-vous de la révolution."

#. [object]
#: .\utils\item_list.cfg:2336
msgid "The gloomy Cloak"
msgstr "La Cape lugubre"

#. [latent]
#: .\utils\item_list.cfg:2349
msgid "<span color='purple'>1 more movement point (requires The gloomy Ring)</span>"
msgstr "<span color='purple'>1 point de mouvement supplémentaire (nécessite L'Anneau lugubre)</span>"

#. [latent]
#: .\utils\item_list.cfg:2355
msgid "<span color='purple'>1 more movement point (requires The gloomy Amulet)</span>"
msgstr "<span color='purple'>1 point de mouvement supplémentaire (nécessite L'Amulette lugubre)</span>"

#. [object]
#: .\utils\item_list.cfg:2360
msgid "Bring sadness to your enemies by showing them how slow they are."
msgstr "Attirez l'attention de vos ennemis en leur montrant à quel point ils sont lents."

#. [object]
#: .\utils\item_list.cfg:2363
msgid "The gloomy Ring"
msgstr "L'Anneau lugubre"

#. [latent]
#: .\utils\item_list.cfg:2374
msgid "<span color='purple'>New Ability: deathaura (requires The gloomy Cloak)</span>"
msgstr "<span color='purple'>Nouvelle capacité : aura de mort (nécessite La Cape lugubre)</span>"

#. [latent]
#: .\utils\item_list.cfg:2382
msgid "<span color='purple'>New Ability: despair (requires The gloomy Amulet)</span>"
msgstr "<span color='purple'>Nouvelle capacité : désespoir (nécessite L'Amulette lugubre)</span>"

#. [object]
#: .\utils\item_list.cfg:2389
msgid "Bring sadness to your enemies by showing them how futile their effort is."
msgstr "Apportez de la tristesse à vos ennemis en leur montrant la futilité de leurs efforts."

#. [object]
#: .\utils\item_list.cfg:2392
msgid "The gloomy Amulet"
msgstr "L'Amulette lugubre"

#. [latent]
#: .\utils\item_list.cfg:2403
msgid "<span color='purple'>+1 base damage (requires The gloomy Cloak)</span>"
msgstr "<span color='purple'>+1 dégâts de base (nécessite La Cape lugubre)</span>"

#. [latent]
#: .\utils\item_list.cfg:2409
msgid "<span color='purple'>+1 base damage (requires The gloomy Ring)</span>"
msgstr "<span color='purple'>+1 dégâts de base (nécessite L'Anneau lugubre)</span>"

#. [object]
#: .\utils\item_list.cfg:2414
msgid "Bring sadness to your enemies by showing them how weak they are."
msgstr "Apportez de la tristesse à vos ennemis en leur montrant à quel point ils sont faibles."

#. [object]
#: .\utils\item_list.cfg:2417
msgid "Serendipity"
msgstr "Sérendipité"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:2427
msgid "You never know what will be learned from here"
msgstr "On ne sait jamais ce que l'on peut apprendre d'ici"

#. [object]
#: .\utils\item_list.cfg:2429
msgid "'Some inventions come out of nowhere.' - Kevla the Saviour"
msgstr "'Certaines inventions sortent de nulle part'. - Kevla le Sauveur"

#. [object]
#: .\utils\item_list.cfg:2432
msgid "Chaosbringer"
msgstr "Porteur du Chaos"

#. [object]
#: .\utils\item_list.cfg:2447
msgid "Do you like order? Shame that I do not."
msgstr "Vous aimez l'ordre ? Dommage que moi non."

#. [object]
#: .\utils\item_list.cfg:2450
msgid "Dagger of Surprises"
msgstr "Dague des Surprises"

#. [object]
#: .\utils\item_list.cfg:2462
msgid "One stab to rule them all."
msgstr "Un seul coup de couteau pour régner sur tous."

#. [object]
#: .\utils\item_list.cfg:2465
msgid "Jawbreaker"
msgstr "Briseur de Mâchoires"

#. [object]
#: .\utils\item_list.cfg:2479
msgid "Why are you grinning like that? It could have killed you!"
msgstr "Pourquoi souris-tu comme ça ? Cela aurait pu te tuer !"

#. [object]
#. [name_variation]
#: .\utils\item_list.cfg:2482
#: .\utils\titles.cfg:1012
msgid "Void"
msgstr "Vide"

#. [object]
#: .\utils\item_list.cfg:2495
msgid "Try to cut through this. There is nothing inside, my guts are in another dimension!"
msgstr "Essayez de couper à travers ça. Il n'y a rien à l'intérieur, mes tripes sont dans une autre dimension !"

#. [object]
#: .\utils\item_list.cfg:2498
msgid "Shako"
msgstr "Shako"

#. [object]
#: .\utils\item_list.cfg:2508
msgid "Nobody would wear this helmet if it was not for its magic."
msgstr "Personne ne porterait ce casque s'il n'était pas magique."

#. [object]
#: .\utils\item_list.cfg:2511
msgid "Potion of Steel Skin"
msgstr "Potion de Peau d'Acier"

#. [object]
#: .\utils\item_list.cfg:2513
msgid "<span color='orange'>Increases physical resistances by 25%</span>"
msgstr "<span color='orange'>Augmente les résistances physiques de 25 %</span>"

#. [object]
#: .\utils\item_list.cfg:2520
msgid "Only magic can make steel bend easily when needed. Or not?"
msgstr "Seule la magie peut permettre à l'acier de se plier facilement lorsque c'est nécessaire. Ou pas ?"

#. [object]
#: .\utils\item_list.cfg:2523
msgid "Robes of Filth"
msgstr "Robes d'Immondices"

#. [object]
#: .\utils\item_list.cfg:2539
msgid "You call my new shirt filth?! For the thirty dirty pins in the sleeves?"
msgstr "Vous appelez ma nouvelle chemise de la saleté ? Pour les trente épingles sales dans les manches ?"

#. [object]
#: .\utils\item_list.cfg:2542
msgid "Draingloves"
msgstr "Gants de Drain"

#. [object]
#: .\utils\item_list.cfg:2559
msgid "You hit, you heal. I hit, you heal. But can you heal enough?"
msgstr "Tu frappes, tu guéris. Je frappe, tu guéris. Mais peux-tu guérir suffisamment ?"

#. [object]
#: .\utils\item_list.cfg:2562
msgid "Cloak of Koschei"
msgstr "Cape de Koschei"

#. [latent]
#: .\utils\item_list.cfg:2577
msgid "<span color='purple'>New ability: Absorbs (1) (requires Koschei's Journal)</span>"
msgstr "<span color='purple'>Nouvelle capacité : Absorbe (1) (nécessite Journal de Koschei)</span>"

#. [object]
#: .\utils\item_list.cfg:2584
msgid "Koschei made it so far on the path of immortality, yet one silly mistake happened to be fatal."
msgstr "Koschei est allé si loin sur le chemin de l'immortalité, mais une erreur stupide lui a été fatale."

#. [object]
#: .\utils\item_list.cfg:2587
msgid "Lucky Farmer's Amulet"
msgstr "Amulette du Fermier Chanceux"

#. [object]
#: .\utils\item_list.cfg:2600
msgid "Look at this trinket I found in my haystack. It will protect me from the atrocities of war."
msgstr "Regardez cette babiole que j'ai trouvée dans ma botte de foin. Il me protégera des atrocités de la guerre."

#. [object]
#: .\utils\item_list.cfg:2603
msgid "Shredder"
msgstr "Déchiqueteur"

#. [object]
#: .\utils\item_list.cfg:2616
msgid "Doing gruesome things to your enemies will enhance their fear and make them weak."
msgstr "Faire subir des choses horribles à vos ennemis renforcera leur peur et les rendra faibles."

#. [object]
#: .\utils\item_list.cfg:2619
msgid "Ancient Armour"
msgstr "Armure Ancienne"

#. [object]
#: .\utils\item_list.cfg:2631
msgid "Our ancestors were very strong if they could carry this around and run in it."
msgstr "Nos ancêtres étaient très forts s'ils pouvaient porter cela et courir avec."

#. [object]
#: .\utils\item_list.cfg:2634
#: .\utils\item_list.cfg:10118
msgid "Ancient Armour of the Power of the Ancients"
msgstr "Ancienne Armure du Pouvoir des Anciens"

#. [object]
#: .\utils\item_list.cfg:2647
#: .\utils\item_list.cfg:10132
msgid "The Ancients knew that imbuing armours with ancient power will make even the most ancient armour useful."
msgstr "Les Anciens savaient qu'en imprégnant les armures d'un pouvoir ancien, même les plus anciennes pouvaient être utiles."

#. [object]
#: .\utils\item_list.cfg:2650
#: .\utils\item_list.cfg:9932
msgid "Mystic Occult Armour of Carpathia"
msgstr "Armure Mystique Occulte de Carpathia"

#. [object]
#: .\utils\item_list.cfg:2661
#: .\utils\item_list.cfg:9944
msgid "Psychospiritual mysticism leads to nocturnal blackness."
msgstr "Le mysticisme psychospirituel conduit à la noirceur nocturne."

#. [object]
#: .\utils\item_list.cfg:2664
msgid "Mask of Famine"
msgstr "Masque de la Famine"

#. [object]
#: .\utils\item_list.cfg:2680
msgid "His hunger... it feeds on everyone nearby!"
msgstr "Sa faim... elle se nourrit de tous ceux qui se trouvent à proximité !"

#. [object]
#: .\utils\item_list.cfg:2683
msgid "Caeordwyccywyrin's Spear"
msgstr "Lance de Caeordwyccywyrin"

#. [object]
#: .\utils\item_list.cfg:2697
msgid "Whose spear is this?"
msgstr "À qui appartient cette lance ?"

#. [object]
#: .\utils\item_list.cfg:2700
msgid "Stardust"
msgstr "Poussière d'Étoile"

#. [object]
#: .\utils\item_list.cfg:2719
msgid "Born from absolute destruction, craving for absolute destruction."
msgstr "Né de la destruction absolue, avide de destruction absolue."

#. [object]
#: .\utils\item_list.cfg:2722
msgid "Guardsman's Leather Armour"
msgstr "Armure de Cuir du Gardien"

#. [object]
#: .\utils\item_list.cfg:2736
msgid "Loyalty will protect you like an expensive armour."
msgstr "La loyauté vous protégera comme une armure coûteuse."

#. [object]
#: .\utils\item_list.cfg:2739
msgid "Greater Guardsman's Leather Armour"
msgstr "Armure de Cuir Supérieur du Garde"

#. [object]
#: .\utils\item_list.cfg:2752
msgid "A good guardsman never yields."
msgstr "Un bon gardien ne capitule jamais."

#. [object]
#: .\utils\item_list.cfg:2755
msgid "Potion of Titanic Strength"
msgstr "Potion de Force Titanesque"

#. [object]
#: .\utils\item_list.cfg:2757
msgid "<span color='orange'>Increases damage of all melee weapons by 10</span>"
msgstr "<span color='orange'>Augmente les dégâts de toutes les armes de mêlée de 10</span>"

#. [object]
#: .\utils\item_list.cfg:2764
msgid "Cronus was the mightiest of the Titans. Only a fraction of his strength is devastating."
msgstr "Cronus était le plus puissant des Titans. Une fraction seulement de sa force est dévastatrice."

#. [object]
#: .\utils\item_list.cfg:2767
msgid "Fleshrending Scourge"
msgstr "Fléau Déchirant la Chair"

#. [object]
#: .\utils\item_list.cfg:2784
msgid "Do not run away from me. I will catch you anyway."
msgstr "Ne me fuis pas. Je te rattraperai de toute façon."

#. [object]
#: .\utils\item_list.cfg:2787
msgid "Boots of Foolish Fighters"
msgstr "Bottes des Combattants Insensés"

#. [object]
#: .\utils\item_list.cfg:2801
msgid "Run fast, hit hard."
msgstr "Courir vite, frapper fort."

#. [object]
#: .\utils\item_list.cfg:2804
msgid "Mountain Trek"
msgstr "Trekking en Montagne"

#. [object]
#: .\utils\item_list.cfg:2825
msgid ""
"'It will take us months to pass through these mountains!'\n"
"'I will wait for you on the other side.'"
msgstr ""
"'Il nous faudra des mois pour traverser ces montagnes'.\n"
"'Je t'attendrai de l'autre côté'."

#. [object]
#: .\utils\item_list.cfg:2829
#: .\utils\item_list.cfg:10135
msgid "Godsmasher"
msgstr "Briseur de Dieux"

#. [object]
#: .\utils\item_list.cfg:2843
#: .\utils\item_list.cfg:10150
msgid ""
"'With this beast, I can kill even a god!'\n"
"'Crunch, munch,... burp. Anybody else thinks that it can kill dragons too?'"
msgstr ""
"'Avec cette bête, je peux tuer même un dieu !'\n"
"'Crunch, munch,... burp. Quelqu'un d'autre pense qu'il peut aussi tuer des dragons ?'"

#. [object]
#: .\utils\item_list.cfg:2847
msgid "Blade Juggler"
msgstr "Jongleur de Lames"

#. [object]
#: .\utils\item_list.cfg:2860
msgid "He threw a dozen knives into the air, catching and throwing them one by one."
msgstr "Il lança une douzaine de couteaux en l'air, les attrapant et les lançant l'un après l'autre."

#. [object]
#: .\utils\item_list.cfg:2863
msgid "Hellrake"
msgstr "Râteau de l'Enfer"

#. [object]
#: .\utils\item_list.cfg:2881
msgid "Flowers bloom in hell too. And every flower has its gardener."
msgstr "Les fleurs fleurissent aussi en enfer. Et chaque fleur a son jardinier."

#. [object]
#: .\utils\item_list.cfg:2884
msgid "Armour of the King"
msgstr "Armure du Roi"

#. [latent]
#: .\utils\item_list.cfg:2906
msgid "<span color='purple'>New Ability: warlord's rule (requires Sceptre of the King)</span>"
msgstr "<span color='purple'>Nouvelle capacité : règne du seigneur de guerre (nécessite Sceptre du Roi)</span>"

#. [latent]
#: .\utils\item_list.cfg:2914
msgid "<span color='purple'>1 more movement point (requires Crown of the King)</span>"
msgstr "<span color='purple'>1 point de mouvement supplémentaire (nécessite Couronne du Roi)</span>"

#. [latent]
#: .\utils\item_list.cfg:2920
msgid "<span color='purple'>4 more hitpoints per level (requires Ring of the King)</span>"
msgstr "<span color='purple'>4 points de vie supplémentaires par niveau (nécessite Anneau du Roi)</span>"

#. [object]
#: .\utils\item_list.cfg:2926
msgid "King's armour protected the usurper, but it did not suffice to prevent wizards from revolting."
msgstr "L'armure du roi a protégé l'usurpateur, mais elle n'a pas suffi à empêcher les sorciers de se révolter."

#. [object]
#: .\utils\item_list.cfg:2929
msgid "Crown of the King"
msgstr "Couronne du Roi"

#. [latent]
#: .\utils\item_list.cfg:2936
msgid "<span color='purple'>New Ability: cantor (requires Ring of the King)</span>"
msgstr "<span color='purple'>Nouvelle capacité : cantor (nécessite Anneau du Roi)</span>"

#. [latent]
#: .\utils\item_list.cfg:2944
#: .\utils\item_list.cfg:2983
msgid "<span color='purple'>+1 to base attacks (requires Armour of the King)</span>"
msgstr "<span color='purple'>+1 aux attaques de base (nécessite Armure du Roi)</span>"

#. [latent]
#: .\utils\item_list.cfg:2950
msgid "<span color='purple'>1 more movement point (requires Sceptre of the King)</span>"
msgstr "<span color='purple'>1 point de mouvement supplémentaire (nécessite Sceptre du Roi)</span>"

#. [object]
#: .\utils\item_list.cfg:2958
msgid "The masses obeyed the one who had the crown. Whoever it was."
msgstr "Les masses obéissaient à celui qui avait la couronne. Qui que ce soit."

#. [object]
#: .\utils\item_list.cfg:2961
msgid "Sceptre of the King"
msgstr "Sceptre du Roi"

#. [latent]
#: .\utils\item_list.cfg:2975
msgid "<span color='purple'>New Ability: radiation (requires Crown of the King)</span>"
msgstr "<span color='purple'>Nouvelle capacité : radiation (nécessite Couronne du Roi)</span>"

#. [latent]
#: .\utils\item_list.cfg:2989
msgid "<span color='purple'>+2 to base damage (requires Ring of the King)</span>"
msgstr "<span color='purple'>+2 aux dégâts de base (nécessite Anneau du Roi)</span>"

#. [object]
#: .\utils\item_list.cfg:2994
msgid "The sceptre was the symbol of king's power. Using it as a weapon did not stop the assassin."
msgstr "Le sceptre est le symbole du pouvoir du roi. L'utiliser comme arme n'a pas arrêté l'assassin."

#. [object]
#: .\utils\item_list.cfg:2997
msgid "Ring of the King"
msgstr "Anneau du Roi"

#. [latent]
#: .\utils\item_list.cfg:3006
msgid "<span color='purple'>New Ability: leadership (level 3) (requires Armour of the King)</span>"
msgstr "<span color='purple'>Nouvelle capacité : commandement (niveau 3) (nécessite Armure du Roi)</span>"

#. [latent]
#: .\utils\item_list.cfg:3014
msgid "<span color='purple'>+1 base damage (requires Crown of the King)</span>"
msgstr "<span color='purple'>+1 dégât de base (nécessite Couronne du Roi)</span>"

#. [latent]
#: .\utils\item_list.cfg:3020
msgid "<span color='purple'>5% to all resistances (requires Sceptre of the King)</span>"
msgstr "<span color='purple'>5 % à toutes les résistances (nécessite Sceptre du Roi)</span>"

#. [object]
#: .\utils\item_list.cfg:3033
msgid "The king was greatly fond of his magical ring. He should have been more fond of his throne."
msgstr "Le roi était très attaché à son anneau magique. Il aurait dû être plus attaché à son trône."

#. [object]
#: .\utils\item_list.cfg:3036
msgid "Virulent Poison"
msgstr "Poison Virulent"

#. [object]
#: .\utils\item_list.cfg:3038
msgid "<span color='orange'>New ability: dark aura</span>"
msgstr "<span color='orange'>Nouvelle capacité : aura sombre</span>"

#. [object]
#: .\utils\item_list.cfg:3049
msgid "He is not only farting poison, he also sweats and burps it."
msgstr "Il ne se contente pas de péter du poison, il en transpire et en rote également."

#. [object]
#: .\utils\item_list.cfg:3052
msgid "Dark Sword of Destruction"
msgstr "Épée Sombre de Destruction"

#. [latent]
#: .\utils\item_list.cfg:3063
msgid "<span color='purple'>+1 to base attacks (requires Dark Helm of Destruction)</span>"
msgstr "<span color='purple'>+1 aux attaques de base (nécessite Heaume Sombre de Destruction)</span>"

#. [latent]
#: .\utils\item_list.cfg:3069
msgid "<span color='purple'>+1 to base attacks (requires Dark Gloves of Destruction)</span>"
msgstr "<span color='purple'>+1 aux attaques de base (nécessite Gants Sombres de Destruction)</span>"

#. [object]
#: .\utils\item_list.cfg:3074
msgid "Real warriors know that their opponents will get heavy armours and prepare for it."
msgstr "Les vrais guerriers savent que leurs adversaires seront équipés d'armures lourdes et s'y préparent."

#. [object]
#: .\utils\item_list.cfg:3077
msgid "Dark Helm of Destruction"
msgstr "Heaume Sombre de Destruction"

#. [latent]
#: .\utils\item_list.cfg:3086
#: .\utils\item_list.cfg:3110
msgid "<span color='purple'>+1 base damage (requires Dark Sword of Destruction)</span>"
msgstr "<span color='purple'>+1 dégâts de base (nécessite Épée Noire de Destruction)</span>"

#. [latent]
#: .\utils\item_list.cfg:3092
msgid "<span color='purple'>+1 base damage (requires Dark Gloves of Destruction)</span>"
msgstr "<span color='purple'>+1 dégâts de base (nécessite Gants Sombres de Destruction)</span>"

#. [object]
#: .\utils\item_list.cfg:3097
msgid "Deadly warriors wear even offensive armour."
msgstr "Les guerriers mortels portent même des armures offensives."

#. [object]
#: .\utils\item_list.cfg:3100
msgid "Dark Gloves of Destruction"
msgstr "Gants Sombres de Destruction"

#. [latent]
#: .\utils\item_list.cfg:3116
msgid "<span color='purple'>+1 base damage (requires Dark Helm of Destruction)</span>"
msgstr "<span color='purple'>+1 dégâts de base (nécessite Heaume Sombre de Destruction)</span>"

#. [object]
#: .\utils\item_list.cfg:3121
msgid "Surviving warriors have learned that healing while fighting is necessary for survival."
msgstr "Les guerriers qui ont survécu ont appris que la guérison pendant le combat est nécessaire à la survie."

#. [object]
#: .\utils\item_list.cfg:3124
msgid "Lethal staff"
msgstr "Bâton Létal"

#. [latent]
#: .\utils\item_list.cfg:3135
msgid "<span color='purple'>10% more overall damage (requires Lethal Axe)</span>"
msgstr "<span color='purple'>10 % de dégâts globaux supplémentaires (nécessite Hache Létale)</span>"

#. [object]
#: .\utils\item_list.cfg:3140
msgid "Most elvish shamans heal. Others kill."
msgstr "La plupart des chamans elfiques soignent. D'autres tuent."

#. [object]
#: .\utils\item_list.cfg:3143
msgid "Lethal Axe"
msgstr "Hache Létale"

#. [latent]
#: .\utils\item_list.cfg:3156
msgid "<span color='purple'>10% more overall damage (requires Lethal Staff)</span>"
msgstr "<span color='purple'>10 % de dégâts globaux supplémentaires (nécessite Bâton Létal)</span>"

#. [object]
#: .\utils\item_list.cfg:3161
msgid "Girls went chopping for revenge. One of them prepared herself quite well."
msgstr "Les filles se sont mises à hacher pour se venger. L'une d'entre elles s'est bien préparée."

#. [object]
#: .\utils\item_list.cfg:3164
msgid "Amulet of Lich's Bane"
msgstr "Amulette du Malheur de la Liche"

#. [object]
#: .\utils\item_list.cfg:3173
msgid "Learn what the enemy will use against you and prepare yourself for it."
msgstr "Apprenez ce que l'ennemi utilisera contre vous et préparez-vous à l'affronter."

#. [object]
#: .\utils\item_list.cfg:3176
msgid "Ring of Devil's Doom"
msgstr "Anneau du Destin du Diable"

#. [object]
#: .\utils\item_list.cfg:3192
msgid "The demonic magic is deadly, but you can prepare yourself to live through it."
msgstr "La magie démoniaque est mortelle, mais vous pouvez vous préparer à y survivre."

#. [object]
#: .\utils\item_list.cfg:3195
msgid "Prismatic Iron Armour"
msgstr "Armure de Fer Prismatique"

#. [object]
#: .\utils\item_list.cfg:3211
msgid "This armour was made to kill wizards, so do not expect it to save you from deadly blades."
msgstr "Cette armure a été conçue pour tuer des sorciers, ne vous attendez donc pas à ce qu'elle vous protège de lames mortelles."

#. [object]
#: .\utils\item_list.cfg:3214
msgid "Leechward"
msgstr "Leechward"

#. [object]
#: .\utils\item_list.cfg:3226
msgid "Transform your blood into acid and nobody will drink it."
msgstr "Transformez votre sang en acide et personne ne le boira."

#. [object]
#: .\utils\item_list.cfg:3229
msgid "The Unraveller"
msgstr "Le Démêleur"

#. [object]
#: .\utils\item_list.cfg:3245
msgid "A mummy cannot be stopped. If it is tangled, it will just unravel the tangled parts."
msgstr "On ne peut pas arrêter une momie. Si elle est emmêlée, elle démêlera les parties emmêlées."

#. [object]
#: .\utils\item_list.cfg:3248
msgid "Sparkling Ring"
msgstr "Bague Étincelante"

#. [object]
#: .\utils\item_list.cfg:3260
msgid "Nobody knows why the yellow-green gemstone in this ring is sparkling."
msgstr "Personne ne sait pourquoi la pierre précieuse jaune-vert de cette bague est étincelante."

#. [object]
#: .\utils\item_list.cfg:3263
msgid "Soul Drinker"
msgstr "Buveur d'Âme"

#. [object]
#: .\utils\item_list.cfg:3275
msgid "The wounded assassin hid in the shadows. Only thrown knives could be seen. Then, he returned healthy."
msgstr "L'assassin blessé s'est caché dans l'ombre. Seuls les couteaux lancés étaient visibles. Puis, il revint en bonne santé."

#. [object]
#: .\utils\item_list.cfg:3278
msgid "Bow of Plagiarism"
msgstr "Arc du Plagiat"

#. [object]
#: .\utils\item_list.cfg:3289
msgid "You have learned something? Well, it will be helpful to me."
msgstr "Vous avez appris quelque chose ? Eh bien, cela me sera utile."

#. [object]
#: .\utils\item_list.cfg:3292
msgid "Horrid Ice Armour"
msgstr "Armure de Glace Horrible"

#. [object]
#: .\utils\item_list.cfg:3303
msgid "Frost not only causes you cold feet, it also kills a peasant's crops, veggies and culinary weed."
msgstr "Le gel ne fait pas que vous donner froid dans le dos, il tue aussi les récoltes, les légumes et les herbes culinaires des paysans."

#. [object]
#: .\utils\item_list.cfg:3306
msgid "Winged Axe"
msgstr "Hache Ailée"

#. [object]
#: .\utils\item_list.cfg:3337
msgid "Each day, he fought bravely in distant lands. Every night, he enjoyed his time with his wife."
msgstr "Chaque jour, il se battait courageusement sur des terres lointaines. Chaque soir, il profite de sa femme."

#. [object]
#: .\utils\item_list.cfg:3340
msgid "Blade of Turisas"
msgstr "Lame de Turisas"

#. [object]
#: .\utils\item_list.cfg:3352
msgid "Every nation had its god of war. Or was it just one with many names?"
msgstr "Chaque nation avait son dieu de la guerre. Ou bien n'en avait-il qu'un seul, aux noms multiples ?"

#. [object]
#: .\utils\item_list.cfg:3355
msgid "Morrígan's Slasher"
msgstr "Slasher de Morrígan"

#. [object]
#: .\utils\item_list.cfg:3372
msgid "Why do these heathens believe that there can be a <b>goddess</b> of war?"
msgstr "Pourquoi ces païens croient-ils qu'il peut y avoir une <b>déesse</b> de la guerre ?"

#. [object]
#: .\utils\item_list.cfg:3375
msgid "Morok's Armour"
msgstr "Armure de Morok"

#. [object]
#: .\utils\item_list.cfg:3391
msgid "Fear the one who calls himself a god of war."
msgstr "Craignez celui qui se dit dieu de la guerre."

#. [object]
#: .\utils\item_list.cfg:3394
msgid "Amulet of Shiva"
msgstr "Amulette de Shiva"

#. [object]
#: .\utils\item_list.cfg:3405
msgid "All shall bow down to the Destroyer."
msgstr "Tous se prosterneront devant le Destructeur."

#. [object]
#: .\utils\item_list.cfg:3408
msgid "Odin's Spear"
msgstr "Lance d'Odin"

#. [object]
#: .\utils\item_list.cfg:3427
msgid "Odin was a warrior, but every winter solstice, he came and brought gifts to kids."
msgstr "Odin était un guerrier, mais à chaque solstice d'hiver, il venait apporter des cadeaux aux enfants."

#. [object]
#: .\utils\item_list.cfg:3430
msgid "Cloak of the Pale Rider"
msgstr "Manteau du Cavalier Pâle"

#. [latent]
#: .\utils\item_list.cfg:3442
msgid "<span color='purple'>+12 to hitpoints (requires Angel of Death's Ring)</span>"
msgstr "<span color='purple'>+12 aux points de vie (nécessite Anneau de l'Ange de la Mort)</span>"

#. [latent]
#: .\utils\item_list.cfg:3448
#: .\utils\item_list.cfg:3482
msgid "<span color='purple'>5% to all resistances (requires Amulet of the Last Guide)</span>"
msgstr "<span color='purple'>5 % à toutes les résistances (nécessite Amulette du Dernier Guide)</span>"

#. [object]
#: .\utils\item_list.cfg:3461
msgid "Do not fear death if it is not near you."
msgstr "Ne craignez pas la mort si elle n'est pas près de vous."

#. [object]
#: .\utils\item_list.cfg:3464
msgid "Angel of Death's Ring"
msgstr "Anneau de l'Ange de la Mort"

#. [latent]
#: .\utils\item_list.cfg:3476
#: .\utils\item_list.cfg:3513
msgid "<span color='purple'>+12 to hitpoints (requires Cloak of the Pale Rider)</span>"
msgstr "<span color='purple'>+12 aux points de vie (nécessite Manteau du Cavalier Pâle)</span>"

#. [object]
#: .\utils\item_list.cfg:3495
msgid "Death is the end, but sometimes an end is needed."
msgstr "La mort est la fin, mais parfois une fin est nécessaire."

#. [object]
#: .\utils\item_list.cfg:3498
msgid "Amulet of the Last Guide"
msgstr "Amulette du Dernier Guide"

#. [latent]
#: .\utils\item_list.cfg:3519
msgid "<span color='purple'>5% to all resistances (requires Angel of Death's Ring)</span>"
msgstr "<span color='purple'>5 % à toutes les résistances (nécessite Anneau de l'Ange de la Mort)</span>"

#. [object]
#: .\utils\item_list.cfg:3532
msgid "Death itself is not evil. Imagine yourself torn to shreds and rotting and having to feel the pain."
msgstr "La Mort n'est pas un mal en soi. Imaginez-vous déchiré en lambeaux, en train de pourrir, et de ressentir la douleur."

#. [object]
#: .\utils\item_list.cfg:3535
msgid "Coward's Bow"
msgstr "Arc du Lâche"

#. [object]
#: .\utils\item_list.cfg:3547
msgid "I am using a bow because I hate being hit. I even have a bow made specially for me."
msgstr "J'utilise un arc parce que je déteste être frappé. J'ai même un arc fait spécialement pour moi."

#. [object]
#: .\utils\item_list.cfg:3550
msgid "Corpsegrinder"
msgstr "Broyeur de Cadavres"

#. [object]
#: .\utils\item_list.cfg:3566
msgid "Mutilating dead enemies makes you forget your woes."
msgstr "Mutiler des ennemis morts vous fait oublier vos malheurs."

#. [object]
#: .\utils\item_list.cfg:3569
msgid "Heart of Darkness"
msgstr "Cœur des Ténèbres"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:3579
msgid "Various wicked spells"
msgstr "Divers Sortilèges Maléfiques"

#. [object]
#: .\utils\item_list.cfg:3581
msgid "Find your dark subconscience and embrace it."
msgstr "Trouvez votre sombre subconscience et embrassez-la."

#. [object]
#: .\utils\item_list.cfg:3584
msgid "Brightslash"
msgstr "Éclat Brillant"

#. [object]
#: .\utils\item_list.cfg:3600
msgid ""
"He came like a shining star,\n"
"allied with the sun,\n"
"he smote the villains,\n"
"and saved the righteous."
msgstr ""
"Il vint comme une étoile brillante,\n"
"allié au soleil,\n"
"il frappa les méchants,\n"
"et il sauva les justes."

#. [object]
#: .\utils\item_list.cfg:3606
msgid "Tears of the Dead"
msgstr "Larmes des Mort"

#. [object]
#: .\utils\item_list.cfg:3621
msgid "Pity the walking dead for they know no pleasure."
msgstr "Pitié pour les morts vivants, car ils ne connaissent pas le plaisir."

#. [object]
#: .\utils\item_list.cfg:3624
msgid "Traces of Blood"
msgstr "Traces de Sang"

#. [object]
#: .\utils\item_list.cfg:3640
msgid "That assassin is hard to find, but his bloody trace can be followed. Shame that it costs so many lives."
msgstr "Cet assassin est difficile à trouver, mais sa trace sanglante peut être suivie. Dommage que cela coûte autant de vies."

#. [object]
#: .\utils\item_list.cfg:3643
msgid "Stormrend"
msgstr "Déchire-Tempête"

#. [object]
#: .\utils\item_list.cfg:3656
msgid "They are protected well. Have them try to survive lightning."
msgstr "Ils sont bien protégés. Faites-leur essayer de survivre à la foudre."

#. [object]
#: .\utils\item_list.cfg:3659
msgid "Precious Eagle Cactus Fruit"
msgstr "Fruit de Cactus Aigle Précieux"

#. [object]
#: .\utils\item_list.cfg:3675
msgid "I need sacrifice. Be it involuntary or not."
msgstr "J'ai besoin de sacrifices. Qu'il soit involontaire ou non."

#. [object]
#: .\utils\item_list.cfg:3678
msgid "Heart of Ice"
msgstr "Coeur de Glace"

#. [latent]
#: .\utils\item_list.cfg:3690
msgid "<span color='purple'>New weapon special: slows (melee attacks only) (requires Iced Boots)</span>"
msgstr "<span color='purple'>Nouvelle spécialité d'attaque : ralentit (attaques de mêlée uniquement) (nécessite Bottes Glacées)</span>"

#. [latent]
#: .\utils\item_list.cfg:3700
#: .\utils\item_list.cfg:3727
msgid "<span color='purple'>+1 base damage (requires Chilling Touch)</span>"
msgstr "<span color='purple'>+1 dégâts de base (nécessite Contact Glacial)</span>"

#. [object]
#: .\utils\item_list.cfg:3705
msgid "Even warm smokes can bring frost. The sun is what we need."
msgstr "Même les fumées chaudes peuvent provoquer des gelées. Le soleil est ce dont nous avons besoin."

#. [object]
#: .\utils\item_list.cfg:3708
msgid "Iced Boots"
msgstr "Bottes Glacées"

#. [latent]
#: .\utils\item_list.cfg:3721
msgid "<span color='purple'>Movement increased by 1 (requires Heart of Ice)</span>"
msgstr "<span color='purple'>Mouvement augmenté de 1 (nécessite Coeur de Glace)</span>"

#. [object]
#: .\utils\item_list.cfg:3732
msgid "When flames fall from the skies or spring from the ground, hot days are not what you should fear."
msgstr "Lorsque les flammes tombent du ciel ou jaillissent du sol, les journées chaudes ne sont pas ce qu'il faut craindre."

#. [object]
#: .\utils\item_list.cfg:3735
msgid "Chilling Touch"
msgstr "Contact Glacial"

#. [latent]
#: .\utils\item_list.cfg:3746
msgid "<span color='purple'>New ability: freezing aura (requires Heart of Ice)</span>"
msgstr "<span color='purple'>Nouvelle capacité : aura glacée (nécessite Cœur de Glace)</span>"

#. [latent]
#: .\utils\item_list.cfg:3754
msgid "<span color='purple'>+1 base damage (requires Iced Boots)</span>"
msgstr "<span color='purple'>+1 dégâts de base (nécessite Bottes Glacées)</span>"

#. [object]
#: .\utils\item_list.cfg:3759
msgid "Unnatural clouds of dust can come and cover the sun. No heat will come and summer crops will be touched by chill."
msgstr "Des nuages de poussière non naturels peuvent venir recouvrir le soleil. Il n'y aura pas de chaleur et les cultures d'été seront touchées par le froid."

#. [object]
#: .\utils\item_list.cfg:3762
msgid "Mental Sheath"
msgstr "Gaine Mentale"

#. [object]
#: .\utils\item_list.cfg:3777
msgid "You can never touch my spirit, you can never catch my soul."
msgstr "Vous ne pourrez jamais toucher mon esprit, vous ne pourrez jamais attraper mon âme."

#. [object]
#: .\utils\item_list.cfg:3780
msgid "Barbaric Glory"
msgstr "Gloire Barbare"

#. [object]
#: .\utils\item_list.cfg:3800
msgid "Abandon the order, attack them randomly when unprepared."
msgstr "Abandonnez l'ordre, attaquez-les au hasard lorsqu'ils ne sont pas préparés."

#. [object]
#: .\utils\item_list.cfg:3803
msgid "The Grey Cloak"
msgstr "La Cape Grise"

#. [object]
#: .\utils\item_list.cfg:3822
msgid "It somewhat reminds me of Gundolf the Great."
msgstr "Cela me rappelle un peu Gundolf le Grand."

#. [object]
#: .\utils\item_list.cfg:3825
msgid "Potion of Mundanity"
msgstr "Potion de Banalité"

#. [object]
#: .\utils\item_list.cfg:3827
msgid "<span color='orange'>This unit's fire, cold and arcane resistances are increased by 60%.</span>"
msgstr "<span color='orange'>Les résistances au feu, au froid et à l'arcane de cette unité sont augmentées de 60 %.</span>"

#. [object]
#: .\utils\item_list.cfg:3835
msgid "What if magic was just a nocebo?"
msgstr "Et si la magie n'était qu'un nocebo ?"

#. [object]
#: .\utils\item_list.cfg:3838
msgid "The Unprecious Ring"
msgstr "L'Anneau Non Précieux"

#. [object]
#: .\utils\item_list.cfg:3851
msgid "Sometimes a fiery or rimy blade is not what you need."
msgstr "Parfois, une lame ardente ou givrée n'est pas ce qu'il vous faut."

#. [object]
#: .\utils\item_list.cfg:3854
msgid "Vanquisher's Mithral Armour"
msgstr "Armure en Mithral du Vainqueur"

#. [object]
#: .\utils\item_list.cfg:3869
msgid "Like a tempest, he landed on his enemies, gore flying everywhere. Even his armour helped him spill blood."
msgstr "Comme une tempête, il atterrit sur ses ennemis, le sang volant partout. Même son armure l'aide à faire couler le sang."

#. [object]
#: .\utils\item_list.cfg:3872
msgid "Dead End Road"
msgstr "Route Sans Issue"

#. [object]
#: .\utils\item_list.cfg:3883
msgid "You will walk away from a necromancer fight. That does not imply that you will survive."
msgstr "Vous quitterez en marchant un combat contre un nécromancien. Cela ne signifie pas que vous survivrez."

#. [object]
#: .\utils\item_list.cfg:3886
#: .\utils\item_list.cfg:9961
msgid "Despicable Heroism"
msgstr "Héroïsme Méprisable"

#. [object]
#: .\utils\item_list.cfg:3900
#: .\utils\item_list.cfg:9976
msgid "Your deeds are revered, but the way you do them is damned."
msgstr "Vos actes sont vénérés, mais la manière dont vous les accomplissez est condamnée."

#. [object]
#: .\utils\item_list.cfg:3903
msgid "Return to the Tribe"
msgstr "Retour à la Tribu"

#. [object]
#: .\utils\item_list.cfg:3921
msgid "I may be no better, but at least I am different."
msgstr "Je ne suis peut-être pas meilleur, mais au moins je suis différent."

#. [object]
#: .\utils\item_list.cfg:3924
msgid "Hands of Sorrow"
msgstr "Mains de la Douleur"

#. [object]
#: .\utils\item_list.cfg:3948
msgid "He grew up as a mercenary bound to obey any command. Remorse led him to distant corners where he died, miserable and alone."
msgstr "Il a grandi comme un mercenaire tenu d'obéir à n'importe quel ordre. Le remords l'a conduit dans des coins reculés où il est mort, misérable et seul."

#. [object]
#: .\utils\item_list.cfg:3951
msgid "Mystic Armour of the Untouchable"
msgstr "Armure Mystique de l'Intouchable"

#. [object]
#: .\utils\item_list.cfg:3971
msgid "Body count matters. I will better let that evasive and well armoured warrior for others."
msgstr "Le nombre de victimes est important. Je préfère laisser ce guerrier évasif et bien armé à d'autres."

#. [object]
#: .\utils\item_list.cfg:3974
msgid "Potion of the Northern Winds"
msgstr "Potion des Vents du Nord"

#. [object]
#: .\utils\item_list.cfg:3976
msgid "<span color='orange'>New ability: northfrost aura</span>"
msgstr "<span color='orange'>Nouvelle capacité : aura de givre nordique</span>"

#. [object]
#: .\utils\item_list.cfg:3987
msgid "I will rule my frostbitten kingdom with an iron hand."
msgstr "Je gouvernerai mon royaume gelé d'une main de fer."

#. [object]
#: .\utils\item_list.cfg:3990
msgid "Aevyn's Wrath"
msgstr "Courroux d'Aevyn"

#. [object]
#: .\utils\item_list.cfg:4009
msgid "I cannot quite figure out how to use this thing."
msgstr "Je n'arrive pas à comprendre comment utiliser cette chose."

#. [object]
#: .\utils\item_list.cfg:4012
msgid "Starbreaker"
msgstr "Briseur d'Étoiles"

#. [object]
#: .\utils\item_list.cfg:4030
msgid "So you are good at blocking? We shall see about that!"
msgstr "Vous êtes donc doué pour bloquer ? C'est ce que nous verrons !"

#. [object]
#: .\utils\item_list.cfg:4033
msgid "Creepy Potion"
msgstr "Potion Effrayante"

#. [object]
#: .\utils\item_list.cfg:4035
msgid ""
"<span color='orange'>New ability: conviction (20)\n"
"New ability: despair (20)</span>"
msgstr ""
"<span color='orange'>Nouvelle capacité : conviction (20)\n"
"Nouvelle capacité : désespoir (20)</span>"

#. [object]
#: .\utils\item_list.cfg:4049
msgid "If you hear me better fear me, if you see me better flee me."
msgstr "Si vous m'entendez, craignez-moi, si vous me voyez, fuyez-moi."

#. [object]
#: .\utils\item_list.cfg:4052
msgid "Potion of Vitality"
msgstr "Potion de Vitalité"

#. [object]
#: .\utils\item_list.cfg:4054
msgid "<span color='orange'>This unit is fully healed and will regenerate health afterwards.</span>"
msgstr "<span color='orange'>Cette unité est entièrement soignée et régénère ses points de vie par la suite.</span>"

#. [object]
#: .\utils\item_list.cfg:4069
msgid "A new life flows in the veins of those who drink this brew."
msgstr "Une nouvelle vie coule dans les veines de ceux qui boivent ce breuvage."

#. [object]
#: .\utils\item_list.cfg:4072
msgid "Brawler's Triumph"
msgstr "Triomphe du Lutteur"

#. [object]
#: .\utils\item_list.cfg:4083
msgid "It protects well... but not as much from punches."
msgstr "Cela protège bien... mais moins bien des coups de poing."

#. [object]
#: .\utils\item_list.cfg:4086
msgid "Iron Armour of the Friendly General"
msgstr "Armure de Fer du Général Amical"

#. [object]
#: .\utils\item_list.cfg:4104
msgid "I will not let you die, my protégé."
msgstr "Je ne te laisserai pas mourir, mon protégé."

#. [object]
#: .\utils\item_list.cfg:4107
msgid "Cunctator's Armour"
msgstr "Armure de Cunctator"

#. [latent]
#: .\utils\item_list.cfg:4127
msgid "<span color='purple'>5% to all resistances (requires Cunctator's Sword)</span>"
msgstr "<span color='purple'>5 % à toutes les résistances (nécessite Épée de Cunctator)</span>"

#. [latent]
#: .\utils\item_list.cfg:4141
msgid "<span color='purple'>5% to all resistances (requires Cunctator's Helmet)</span>"
msgstr "<span color='purple'>5 % à toutes les résistances (nécessite Casque de Cunctator)</span>"

#. [object]
#: .\utils\item_list.cfg:4154
msgid "Enemies were bored to death when Cunctator finally attacked."
msgstr "Les ennemis s'ennuyaient à mourir lorsque Cunctator a finalement attaqué."

#. [object]
#: .\utils\item_list.cfg:4157
msgid "Cunctator's Helmet"
msgstr "Casque de Cunctator"

#. [latent]
#: .\utils\item_list.cfg:4174
msgid "<span color='purple'>New ability: careful (10) (requires Cunctator's Sword)</span>"
msgstr "<span color='purple'>Nouvelle capacité : prudence (10) (nécessite Épée de Cunctator)</span>"

#. [latent]
#: .\utils\item_list.cfg:4182
msgid "<span color='purple'>10% to physical resistances (requires Cunctator's Armour)</span>"
msgstr "<span color='purple'>10% de résistances physique (nécessite l'Armure de Cunctator)</span>"

#. [object]
#: .\utils\item_list.cfg:4192
msgid "If you command Cunctator to attack immediately, he will not obey."
msgstr "Si vous ordonnez à Cunctator d'attaquer immédiatement, il n'obéira pas."

#. [object]
#: .\utils\item_list.cfg:4195
msgid "Lilith's Precious"
msgstr "Précieux de Lilith"

#. [object]
#: .\utils\item_list.cfg:4209
#: .\utils\item_list.cfg:9753
#: .\utils\item_list.cfg:10044
msgid "In order to be able to fight with any weapon available, Lilith swaps weapon types once per century."
msgstr "Afin de pouvoir se battre avec n'importe quelle arme, Lilith change de type d'arme une fois par siècle."

#. [object]
#: .\utils\item_list.cfg:4212
msgid "Mithral Armour of Wrath"
msgstr "Armure de Courroux en Mithral"

#. [object]
#: .\utils\item_list.cfg:4231
msgid "Forged for the elite among Dwarvish Berserkers."
msgstr "Forgé pour l'élite des Berserkers Nains."

#. [object]
#: .\utils\item_list.cfg:4234
msgid "Preacher of Hatred"
msgstr "Prédicateur de la Haine"

#. [object]
#: .\utils\item_list.cfg:4257
msgid "Your descendants, ancestors and friends are demonic kin that is behind all our suffering."
msgstr "Vos descendants, ancêtres et amis sont des êtres démoniaques qui sont à l'origine de toutes nos souffrances."

#. [object]
#: .\utils\item_list.cfg:4260
msgid "Titan's Bane"
msgstr "Fléau du Titan"

#. [object]
#: .\utils\item_list.cfg:4270
msgid "My blows may cause mere scratches on your skin, but it can be enough for you to die."
msgstr "Mes coups peuvent causer de simples égratignures sur ta peau, mais cela peut suffire pour que tu meures."

#. [object]
#: .\utils\item_list.cfg:4273
msgid "Ashes of Dead Suns"
msgstr "Cendres des Soleils Morts"

#. [object]
#: .\utils\item_list.cfg:4285
msgid "Things that destroy stars can destroy anything. According to one of a thousand hypotheses."
msgstr "Les choses qui détruisent les étoiles peuvent détruire n'importe quoi. Selon une hypothèse parmi mille autres."

#. [object]
#: .\utils\item_list.cfg:4288
msgid "The Deadborn"
msgstr "Le Mort-Né"

#. [object]
#: .\utils\item_list.cfg:4298
msgid "Darkest legends tell of necromancers creating undead so pure that they were never tainted by life, dead from birth."
msgstr "Les légendes les plus sombres racontent que des nécromanciens ont créé des morts-vivants si purs qu'ils n'ont jamais été contaminés par la vie, morts dès leur naissance."

#. [object]
#: .\utils\item_list.cfg:4301
msgid "Raijer's Bloody Field"
msgstr "Champ sanglant de Raijer"

#. [effect], apply_to=new_advancement
#: .\utils\item_list.cfg:4310
msgid "Techniques of extracting the victim's soul and using it for own profit"
msgstr "Techniques pour extraire l'âme de la victime et l'utiliser à son profit"

#. [object]
#: .\utils\item_list.cfg:4312
msgid "Those who are the first of their kinds are often the mightiest of them."
msgstr "Les premiers de leur espèce sont souvent les plus puissants."

#. [object]
#: .\utils\item_list.cfg:4315
msgid "Xuanquang's Soul Harvest"
msgstr "Récolte d'âmes de Xuanquang"

#. [object]
#: .\utils\item_list.cfg:4333
msgid "Don't be afraid when seeing a bloody road. Keep calm and turn back to face the one who made it so bloody."
msgstr "N'ayez pas peur lorsque vous voyez une route ensanglantée. Gardez votre calme et retournez-vous pour faire face à celui qui l'a ensanglantée."

#. [object]
#: .\utils\item_list.cfg:4336
msgid "Soul Thrash"
msgstr "Raclée d'Âme"

#. [object]
#: .\utils\item_list.cfg:4355
msgid ""
"'My life is in ruins, if I die, I cannot lose anything.'\n"
"Then he saw this item."
msgstr ""
"'Ma vie est en ruine, si je meurs, je ne peux rien perdre'.\n"
"C'est alors qu'il a vu cet objet."

#. [object]
#: .\utils\item_list.cfg:4359
msgid "Steps to Perdition"
msgstr "Marche vers la Perdition"

#. [object]
#: .\utils\item_list.cfg:4377
msgid "I agree that you are effective, but it still leads to disaster - one accident and you are dead."
msgstr "Je suis d'accord pour dire que vous êtes efficace, mais cela mène toujours au désastre - un accident et vous êtes mort."

#. [object]
#: .\utils\item_list.cfg:4380
msgid "Relentless Fury"
msgstr "Fureur Implacable"

#. [object]
#: .\utils\item_list.cfg:4395
msgid "You tell that my hits are weak? I will show you how many of them you can survive, nothing can stop me!"
msgstr "Tu dis que mes coups sont faibles ? Je vais te montrer à combien de coups tu peux survivre, rien ne peut m'arrêter !"

#. [object]
#: .\utils\item_list.cfg:4398
msgid "Visions of Cruelty"
msgstr "Visions de Cruauté"

#. [object]
#: .\utils\item_list.cfg:4411
msgid "There is cruelty. As far as I can see, cruelty is everywhere."
msgstr "La cruauté existe. D'après ce que je vois, la cruauté est partout."

#. [object]
#: .\utils\item_list.cfg:4414
msgid "Heavy Gauntlets of Virility"
msgstr "Gantelets Lourds de Virilité"

#. [object]
#: .\utils\item_list.cfg:4430
msgid "It protects you well, but are you sure that you can lift a weapon with that?"
msgstr "Il vous protège bien, mais êtes-vous sûr de pouvoir soulever une arme avec ça ?"

#. [object]
#: .\utils\item_list.cfg:4433
msgid "Slow Boots of Certainty"
msgstr "Bottes Lentes de Certitude"

#. [object]
#: .\utils\item_list.cfg:4447
msgid "I could have been here yesterday, but it was not worth the danger."
msgstr "J'aurais pu être ici hier, mais le danger n'en valait pas la peine."

#. [object]
#: .\utils\item_list.cfg:4450
msgid "The Nightreaver"
msgstr "Le Tueur de Nuit"

#. [object]
#: .\utils\item_list.cfg:4464
msgid "Aggressive and violent, they strike when least expected and take away all serenity."
msgstr "Agressifs et violents, ils frappent au moment où l'on s'y attend le moins et enlèvent toute sérénité."

#. [object]
#: .\utils\item_list.cfg:4467
msgid "Bringer of Fragility"
msgstr "Apporteur de Fragilité"

#. [object]
#: .\utils\item_list.cfg:4486
msgid "How can a weapon and armour this heavy be so ineffective?!"
msgstr "Comment une arme et une armure aussi lourdes peuvent-elles être aussi inefficaces ?!"

#. [object]
#: .\utils\item_list.cfg:4489
msgid "Fiery Blood"
msgstr "Sang Ardent"

#. [object]
#: .\utils\item_list.cfg:4501
msgid "Red is the fire. Red is the blood. I am not sure which of them is pouring."
msgstr "Le rouge est le feu. Le rouge est le sang. Je ne sais pas lequel des deux est versé."

#. [object]
#: .\utils\item_list.cfg:4504
msgid "False Paradise"
msgstr "Faux Paradis"

#. [object]
#: .\utils\item_list.cfg:4522
msgid "Their society was almost utopian. They grew lazy and weak and became an easy prey for invaders."
msgstr "Leur société était presque utopique. Ils devinrent paresseux et faibles et constituèrent une proie facile pour les envahisseurs."

#. [object]
#: .\utils\item_list.cfg:4525
msgid "The Outcast"
msgstr "Le Proscrit"

#. [object]
#: .\utils\item_list.cfg:4547
msgid "Loneliness will teach you to stop relying on others. It makes you free if you pay its price."
msgstr "La solitude vous apprendra à ne plus compter sur les autres. Elle vous rend libre si vous en payez le prix."

#. [object]
#: .\utils\item_list.cfg:4550
msgid "Cursed Memories"
msgstr "Souvenirs Maudits"

#. [object]
#: .\utils\item_list.cfg:4564
msgid "Every hero suffers from horrors of the past. Only a few can have their enemies suffer from them instead."
msgstr "Tous les héros souffrent des horreurs du passé. Seuls quelques-uns peuvent faire souffrir leurs ennemis à leur place."

#. [object]
#: .\utils\item_list.cfg:4567
msgid "Spectral Jet"
msgstr "Jet Spectral"

#. [object]
#: .\utils\item_list.cfg:4581
msgid "When you die, you should not expect your soul to go where you think it belongs."
msgstr "Lorsque vous mourrez, vous ne devez pas vous attendre à ce que votre âme aille là où vous pensez qu'elle doit aller."

#. [object]
#: .\utils\item_list.cfg:4584
msgid "The Humongously Enormous Megaspear"
msgstr "L'Énorme Mégalance Gargantuesque"

#. [object]
#: .\utils\item_list.cfg:4596
msgid "Small weapons are for wimps."
msgstr "Les petites armes sont faites pour les mauviettes."

#. [object]
#: .\utils\item_list.cfg:4599
msgid "Unseen Writings"
msgstr "Écrits Invisibles"

#. [latent]
#: .\utils\item_list.cfg:4612
msgid "<span color='purple'>4% to magical resistances (requires Unspoken Words)</span>"
msgstr "<span color='purple'>4 % aux résistances magiques (nécessite Mots Ineffables)</span>"

#. [latent]
#: .\utils\item_list.cfg:4623
msgid "<span color='purple'>New base ranged weapon special: struggle (requires Unthought Memories)</span>"
msgstr "<span color='purple'>Nouvelle spécialité d'attaque à distance : lutte (nécessite Souvenirs Impensés)</span>"

#. [latent]
#: .\utils\item_list.cfg:4633
msgid "<span color='purple'>4% to all physical resistances (requires Unsung Odes)</span>"
msgstr "<span color='purple'>4 % à toutes les résistances physiques (nécessite Odes Inchantées)</span>"

#. [object]
#: .\utils\item_list.cfg:4643
msgid "No matter how well you write, after a millenium there will be nothing of it. Though copies may survive."
msgstr "Quelle que soit la qualité de vos écrits, il n'en restera rien après un millénaire. Bien que des copies puissent survivre."

#. [object]
#: .\utils\item_list.cfg:4646
msgid "Unspoken Words"
msgstr "Mots Ineffables"

#. [latent]
#: .\utils\item_list.cfg:4660
#: .\utils\item_list.cfg:4711
msgid "<span color='purple'>4% to all physical resistances (requires Unseen Writings)</span>"
msgstr "<span color='purple'>4 % à toutes les résistances physiques (requiert Écrits Invisibles)</span>"

#. [latent]
#: .\utils\item_list.cfg:4671
#: .\utils\item_list.cfg:4788
msgid "<span color='purple'>4% to magical resistances (requires Unthought Memories)</span>"
msgstr "<span color='purple'>4 % aux résistances magiques (requiert Souvenirs Impensés)</span>"

#. [latent]
#: .\utils\item_list.cfg:4682
msgid "<span color='purple'>2% to all resistances (requires Unsung Odes)</span>"
msgstr "<span color='purple'>2 % à toutes les résistances (nécessite Odes Inchantées)</span>"

#. [object]
#: .\utils\item_list.cfg:4695
msgid "No matter how wise you are, your words once shall be forgotten. But meaning may remain."
msgstr "Quelle que soit votre sagesse, vos paroles seront un jour oubliées. Mais le sens peut rester."

#. [object]
#: .\utils\item_list.cfg:4698
msgid "Unthought Memories"
msgstr "Souvenirs Impensés"

#. [latent]
#: .\utils\item_list.cfg:4722
msgid "<span color='purple'>2% to all resistances (requires Unspoken Words)</span>"
msgstr "<span color='purple'>2 % à toutes les résistances (nécessite Mots Ineffables)</span>"

#. [latent]
#: .\utils\item_list.cfg:4736
msgid "<span color='purple'>4% to magical resistances (requires Unsung Odes)</span>"
msgstr "<span color='purple'>4 % aux résistances magiques (nécessite Odes Inchantées)</span>"

#. [object]
#: .\utils\item_list.cfg:4746
msgid "Your life's experience may disappear when you perish, but once somebody will come to the same experience."
msgstr "L'expérience de votre vie peut disparaître lorsque vous périssez, mais une fois, quelqu'un fera la même expérience."

#. [object]
#: .\utils\item_list.cfg:4749
msgid "Unsung Odes"
msgstr "Odes Inchantées"

#. [latent]
#: .\utils\item_list.cfg:4763
msgid "<span color='purple'>2% to all resistances (requires Unseen Writings)</span>"
msgstr "<span color='purple'>2 % à toutes les résistances (nécessite Écrits Invisibles)</span>"

#. [latent]
#: .\utils\item_list.cfg:4777
msgid "<span color='purple'>4% to all physical resistances (requires Unspoken Words)</span>"
msgstr "<span color='purple'>4 % à toutes les résistances physiques (nécessite Mots Ineffables)</span>"

#. [object]
#: .\utils\item_list.cfg:4798
msgid "Your deeds of valour will not be revered forever. But their consequences will not vanish."
msgstr "Vos actes de bravoure ne seront pas vénérés éternellement. Mais leurs conséquences ne disparaîtront pas."

#. [object]
#: .\utils\item_list.cfg:4801
msgid "Fist of Anarchy"
msgstr "Poing d'Anarchie"

#. [object]
#: .\utils\item_list.cfg:4814
msgid "Rebirth through devastation, freedom through bloodshed."
msgstr "Renaissance par dévastation, liberté par effusion de sang."

#. [object]
#: .\utils\item_list.cfg:4817
msgid "Misery's Crown"
msgstr "Couronne de la Misère"

#. [object]
#: .\utils\item_list.cfg:4833
msgid "Do not bring your misery down on me."
msgstr "Ne m'inflige pas ton malheur."

#. [object]
#: .\utils\item_list.cfg:4836
msgid "Dark Sarcasm"
msgstr "Sarcasme Sombre"

#. [object]
#: .\utils\item_list.cfg:4851
msgid "You missed! You cannot even hit me! Hahahaha! I feel so good to see you fail, loser!"
msgstr "T'as raté ton coup ! Tu ne peux même pas me toucher ! Hahahaha ! Ça me fait du bien de te voir rater, loser !"

#. [object]
#: .\utils\item_list.cfg:4854
msgid "Beyond Death"
msgstr "Au-delà de la Mort"

#. [object]
#: .\utils\item_list.cfg:4868
msgid "Death can be temporary."
msgstr "La mort peut être temporaire."

#. [object]
#: .\utils\item_list.cfg:4871
msgid "Avenging Fire"
msgstr "Feu Vengeur"

#. [object]
#: .\utils\item_list.cfg:4887
msgid "Burn! Let the hair catch fire and help the skin burn. Ignite the skin and help the flesh burn."
msgstr "Brûlez ! Laissez les cheveux s'enflammer et aidez la peau à brûler. Enflammez la peau et aidez la chair à brûler."

#. [object]
#: .\utils\item_list.cfg:4890
msgid "The Sick Face"
msgstr "Le Visage Malade"

#. [object]
#: .\utils\item_list.cfg:4911
msgid "He looks sick. Killing him will be easy, just try not to catch whatever he has."
msgstr "Il a l'air malade. Le tuer sera facile, essayez juste de ne pas attraper ce qu'il a."

#. [object]
#: .\utils\item_list.cfg:4914
msgid "Black Raptor"
msgstr "Rapace Noir"

#. [object]
#: .\utils\item_list.cfg:4932
msgid "Birds look upwards to avoid eagles. They should look down to avoid hunters."
msgstr "Les oiseaux regardent vers le haut pour éviter les aigles. Ils doivent regarder vers le bas pour éviter les chasseurs."

#. [object]
#: .\utils\item_list.cfg:4935
msgid "Otherworldly Cinders"
msgstr "Cendres d'un Autre Monde"

#. [object]
#: .\utils\item_list.cfg:4937
msgid ""
"<span color='orange'>Resist fire 40%\n"
"New ability: from the ashes</span>"
msgstr ""
"<span color='orange'>Résistance au feu 40 %.\n"
"Nouvelle capacité : depuis les cendres</span>"

#. [object]
#: .\utils\item_list.cfg:4951
msgid "Arise, the bird of death, burn when you die and reappear from your flames."
msgstr "Lève-toi, l'oiseau de la mort, brûle quand tu meurs et réapparais de tes flammes."

#. [object]
#: .\utils\item_list.cfg:4954
msgid "Havoc Bliss"
msgstr "Félicité de la Dévastation"

#. [object]
#: .\utils\item_list.cfg:4967
msgid "Destruction can save you from suffering if you do it right."
msgstr "La destruction peut vous épargner des souffrances si vous vous y prenez bien."

#. [object]
#: .\utils\item_list.cfg:4970
msgid "Iridium"
msgstr "Iridium"

#. [object]
#: .\utils\item_list.cfg:4980
msgid "Mages hypothetise that there is an extremely heavy metal that its ore's weight pulls it into depths."
msgstr "Les mages supposent qu'il existe un métal extrêmement lourd que le poids de son minerai entraîne dans les profondeurs."

#. [object]
#: .\utils\item_list.cfg:4983
msgid "Potion of Sacrifice"
msgstr "Potion de Sacrifice"

#. [object]
#: .\utils\item_list.cfg:4985
msgid "<span color='orange'>All adjacent allies are infuriated if the drinker of this potion gets hit</span>"
msgstr "<span color='orange'>Tous les alliés adjacents sont furieux si le buveur de cette potion est touché</span>"

#. [object]
#: .\utils\item_list.cfg:4997
msgid "'I will need you to understand the conception of divine sacrifice.' - Luke"
msgstr "'Je vais avoir besoin que vous compreniez le concept de sacrifice divin.' - Luc"

#. [object]
#: .\utils\item_list.cfg:5000
msgid "Rationality"
msgstr "Rationalité"

#. [object]
#: .\utils\item_list.cfg:5010
msgid "Magic is just very well made quackery."
msgstr "La magie n'est que du charlatanisme très bien fait."

#. [object]
#: .\utils\item_list.cfg:5013
msgid "Crushing Walk"
msgstr "Marche Écrasante"

#. [object]
#: .\utils\item_list.cfg:5025
msgid "Sometimes I am not looking where I step and the casualties can be significant."
msgstr "Parfois, je ne regarde pas où je mets les pieds et les pertes peuvent être importantes."

#. [object]
#: .\utils\item_list.cfg:5028
msgid "Redshirt Armour"
msgstr "Armure Chemise-Rouge"

#. [object]
#: .\utils\item_list.cfg:5050
msgid "Why do they all try to kill that man?"
msgstr "Pourquoi essaient-ils tous de tuer cet homme ?"

#. [object]
#: .\utils\item_list.cfg:5053
msgid "Hope of the Fallen"
msgstr "Espoir des Déchus"

#. [object]
#: .\utils\item_list.cfg:5067
msgid "Dark immortality is encased in great sadness, but the encasement has its flaws."
msgstr "L'immortalité sombre est enveloppée d'une grande tristesse, mais l'enveloppe a ses défauts."

#. [object]
#: .\utils\item_list.cfg:5070
msgid "Fowleri's Chopper"
msgstr "Hachoir de Fowleri"

#. [object]
#: .\utils\item_list.cfg:5092
msgid "He broke her heart. No, wait, not heart, sanity. He broke her sanity."
msgstr "Il lui a brisé le cœur. Non, attendez, pas cœur, santé mentale. Il a brisé sa santé mentale."

#. [object]
#: .\utils\item_list.cfg:5095
msgid "Acantha's Cloak"
msgstr "Manteau d'Acantha"

#. [object]
#: .\utils\item_list.cfg:5105
msgid "She was forced to abandon politics and care about children. She indoctrinated them with evil."
msgstr "Elle a été contrainte d'abandonner la politique et de s'occuper des enfants. Elle les a endoctrinés avec le mal."

#. [object]
#: .\utils\item_list.cfg:5108
msgid "Marilyn's Armour"
msgstr "Armure de Marilyn"

#. [object]
#: .\utils\item_list.cfg:5124
msgid "A manly man can have a woman's name without being funny."
msgstr "Un homme viril peut porter un nom de femme sans que cela ne soit drôle."

#. [object]
#: .\utils\item_list.cfg:5127
msgid "Mother de Rais"
msgstr "Mère de Rais"

#. [object]
#: .\utils\item_list.cfg:5151
msgid "The undead were too numerous to be burned by her fireballs. She had to jump into a river far below to save herself."
msgstr "Les morts-vivants étaient trop nombreux pour être brûlés par ses boules de feu. Elle a dû sauter dans une rivière en contrebas pour se sauver."

#. [object]
#: .\utils\item_list.cfg:5154
msgid "Sceptre of Antipater"
msgstr "Sceptre d'Antipater"

#. [object]
#: .\utils\item_list.cfg:5172
msgid "You can be evil even if you heal people."
msgstr "On peut être mauvais même si l'on soigne les gens."

#. [object]
#: .\utils\item_list.cfg:5175
msgid "Bow of Many Arrows"
msgstr "Arc à Nombreuses Flèches"

#. [object]
#: .\utils\item_list.cfg:5188
msgid "There must be a thousand archers over there, but I see only one!"
msgstr "Il doit y avoir un millier d'archers là-bas, mais je n'en vois qu'un seul !"

#. [object]
#: .\utils\item_list.cfg:5191
msgid "What no man should know"
msgstr "Ce qu'aucun homme ne devrait savoir"

#. [object]
#: .\utils\item_list.cfg:5210
msgid "I saw a man, frozen solid in a midsummer day. He had this pretty helmet, let me try it on..."
msgstr "J'ai vu un homme, gelé en plein été. Il avait ce joli casque, laissez-moi l'essayer..."

#. [object]
#: .\utils\item_list.cfg:5213
msgid "The Ragtag Misfit"
msgstr "L'Indiscipliné Associal"

#. [object]
#: .\utils\item_list.cfg:5228
msgid "All I want is your love... Yes, I know I will get no love, but I will get your gold at least."
msgstr "Tout ce que je veux, c'est ton amour... Oui, je sais que je n'aurai pas d'amour, mais j'aurai au moins ton or."

#. [object]
#: .\utils\item_list.cfg:5231
msgid "Stolen Potion"
msgstr "Potion Volée"

#. [object]
#: .\utils\item_list.cfg:5233
msgid ""
"<span color='orange'>New ability: Skirmisher\n"
"New ability: Steals</span>"
msgstr ""
"<span color='orange'>Nouvelle capacité : Tirailleur\n"
"Nouvelle capacité : Vol</span>"

#. [object]
#: .\utils\item_list.cfg:5247
msgid "I have stolen this. Now all the world is here for me to steal."
msgstr "J'ai volé ceci. Maintenant le monde entier est à moi à voler."

#. [object]
#: .\utils\item_list.cfg:5250
msgid "Herod's Mithral Armour"
msgstr "Armure de Mithral d'Hérode"

#. [abilities]
#: .\utils\item_list.cfg:5265
#: .\utils\item_list.cfg:5316
#: .\utils\item_list.cfg:6257
#: .\utils\item_list.cfg:8700
#: .\utils\item_list.cfg:8828
msgid "damage aura"
msgstr "aura de dégâts"

#. [object]
#: .\utils\item_list.cfg:5269
msgid "He was a powerful ruler, but he was not very righteous. No wonder that his cousin dethroned him."
msgstr "C'était un souverain puissant, mais il n'était pas très vertueux. Il n'est donc pas étonnant que son cousin l'ait détrôné."

#. [object]
#: .\utils\item_list.cfg:5272
msgid "Stormgrip"
msgstr "Poigne Orageuse"

#. [object]
#: .\utils\item_list.cfg:5282
msgid "You are an evil overlord, armoured and shielded against everything? I will slay you anyway."
msgstr "Vous êtes un seigneur maléfique, blindé et protégé contre tout ? Je vous tuerai quand même."

#. [object]
#: .\utils\item_list.cfg:5285
msgid "The Crusher"
msgstr "Le Broyeur"

#. [object]
#: .\utils\item_list.cfg:5296
msgid "I will send my assassins to slay the lich. You will gear them properly."
msgstr "J'enverrai mes assassins tuer la liche. Vous les équiperez correctement."

#. [object]
#: .\utils\item_list.cfg:5299
msgid "Hatred for Men"
msgstr "Haine des hommes"

#. [object]
#: .\utils\item_list.cfg:5319
msgid "Fuelled by the venom and hatred."
msgstr "Alimenté par le venin et la haine."

#. [object]
#: .\utils\item_list.cfg:5322
msgid "Crapsack World"
msgstr "Crapsack World"

#. [object]
#: .\utils\item_list.cfg:5340
msgid ""
"'Oh, almighty god, why did you create this world?'\n"
"'It was not me. I have a perfect alibi, by the way.'"
msgstr ""
"'Oh, Dieu tout-puissant, pourquoi as-tu créé ce monde ?'\n"
"'Ce n'était pas moi. J'ai d'ailleurs un alibi parfait.'"

#. [object]
#: .\utils\item_list.cfg:5344
#: .\utils\item_list.cfg:10154
msgid "The Touch of God"
msgstr "Le Toucher de Dieu"

#. [object]
#: .\utils\item_list.cfg:5360
#: .\utils\item_list.cfg:10171
msgid ""
"'I... I have been touched by god.'\n"
"'Touched by our almighty lord and saviour?'\n"
"'No, by lord Cthulhu.'"
msgstr ""
"'J'... J'ai été touché par dieu.\n"
"Touché par notre tout-puissant seigneur et sauveur ?\n"
"Non, par le seigneur Cthulhu."

#. [object]
#: .\utils\item_list.cfg:5365
msgid "The Warmth"
msgstr "La Chaleur"

#. [object]
#: .\utils\item_list.cfg:5381
msgid "Solace from depressive gloom of northern winters when dusk follows dawn with nothing in between."
msgstr "Un réconfort contre la morosité dépressive des hivers nordiques, lorsque le crépuscule succède à l'aube sans rien entre les deux."

#. [object]
#: .\utils\item_list.cfg:5384
msgid "Apricity"
msgstr "Héliothermie"

#. [object]
#: .\utils\item_list.cfg:5397
msgid "In winter, the burning sun is actually enjoyable."
msgstr "En hiver, le soleil brûlant est en fait agréable."

#. [object]
#: .\utils\item_list.cfg:5400
msgid "Pyromancer's Sword"
msgstr "Épée du Pyromancien"

#. [latent]
#: .\utils\item_list.cfg:5412
msgid "<span color='purple'>New ability: firecast (requires Pyromancer's Ring)</span>"
msgstr "<span color='purple'>Nouvelle capacité : jet de feu (nécessite Anneau du Pyromancien)</span>"

#. [latent]
#: .\utils\item_list.cfg:5420
msgid "<span color='purple'>5% to magical resistances (requires Pyromancer's Cloak)</span>"
msgstr "<span color='purple'>5 % aux résistances magiques (nécessite Cape du Pyromancien)</span>"

#. [object]
#: .\utils\item_list.cfg:5430
msgid "Flames were his nature, they replaced his insides."
msgstr "Les flammes étaient sa nature, elles remplaçaient ses entrailles."

#. [object]
#: .\utils\item_list.cfg:5433
msgid "Pyromancer's Ring"
msgstr "Anneau du Pyromancien"

#. [latent]
#: .\utils\item_list.cfg:5444
msgid "<span color='purple'>New attack: fireball (11-4 fire damage, magical) (requires Pyromancer's Sword)</span>"
msgstr "<span color='purple'>Nouvelle attaque : boule de feu (11-4 dégâts de feu, magique) (nécessite Épée du Pyromancien)</span>"

#. [latent]
#: .\utils\item_list.cfg:5482
msgid "<span color='purple'>Damage increased by 2 (requires Pyromancer's Cloak)</span>"
msgstr "<span color='purple'>Dégâts augmentés de 2 (nécessite Cape du Pyromancien)</span>"

#. [object]
#: .\utils\item_list.cfg:5487
msgid "He could feed on fire and magic, spitting it back on those who tried to harm him with it."
msgstr "Il pouvait se nourrir de feu et de magie, les recrachant sur ceux qui essayaient de lui faire du mal."

#. [object]
#: .\utils\item_list.cfg:5490
msgid "Pyromancer's Cloak"
msgstr "Cape du Pyromancien"

#. [latent]
#: .\utils\item_list.cfg:5501
msgid "<span color='purple'>5% to magical resistances (requires Pyromancer's Sword)</span>"
msgstr "<span color='purple'>5 % aux résistances magiques (nécessite Épée du Pyromancien)</span>"

#. [latent]
#: .\utils\item_list.cfg:5512
msgid "<span color='purple'>New ability: from the ashes (requires Pyromancer's Ring)</span>"
msgstr "<span color='purple'>Nouvelle capacité : depuis les cendres (nécessite Anneau du Pyromancien)</span>"

#. [object]
#: .\utils\item_list.cfg:5519
msgid "When his body was destroyed, he rose again from the ashes."
msgstr "Après la destruction de son corps, il renaquit de ses cendres."

#. [object]
#: .\utils\item_list.cfg:5522
msgid "Virtual Void"
msgstr "Vide Virtuel"

#. [object]
#: .\utils\item_list.cfg:5533
msgid "The pure shall be overridden."
msgstr "Le pur doit être outrepassé."

#. [object]
#: .\utils\item_list.cfg:5536
msgid "Lake of Blood"
msgstr "Lac de Sang"

#. [object]
#: .\utils\item_list.cfg:5553
msgid "Liquids soak into the ground. To fill a lake, you have to gather liquids fast."
msgstr "Les liquides s'infiltrent dans le sol. Pour remplir un lac, il faut recueillir rapidement les liquides."

#. [object]
#: .\utils\item_list.cfg:5556
msgid "Paranoia"
msgstr "Paranoïa"

#. [object]
#: .\utils\item_list.cfg:5572
msgid "Every face is an enemy."
msgstr "Chaque visage est un ennemi."

#. [object]
#: .\utils\item_list.cfg:5575
msgid "The Parasite"
msgstr "Le Parasite"

#. [object]
#: .\utils\item_list.cfg:5594
msgid ""
"They make promises of the impossible.\n"
"They say they guide you to reach the impossible.\n"
"They pretend you had reached the impossible.\n"
"If you do not believe them, you did it wrong."
msgstr ""
"Ils promettent l'impossible.\n"
"Ils disent qu'ils vous guident pour atteindre l'impossible.\n"
"Ils prétendent que vous avez atteint l'impossible.\n"
"Si vous ne les croyez pas, c'est que vous l'avez mal fait."

#. [object]
#: .\utils\item_list.cfg:5600
msgid "Fire-Forged Friend"
msgstr "Ami Forgé par le Feu"

#. [object]
#: .\utils\item_list.cfg:5602
msgid ""
"<span color='orange'>50% increased physical resistances\n"
"-4 movement speed</span>"
msgstr ""
"<span color='orange'>50 % d'augmentation des résistances physiques\n"
"-4 vitesse de déplacement</span>"

#. [object]
#: .\utils\item_list.cfg:5617
msgid "'I make my friends with hammer and anvil.' -Pygmaliophaestus"
msgstr "'Je fais mes amis avec le marteau et l'enclume'. -Pygmaliophaestus"

#. [object]
#: .\utils\item_list.cfg:5620
msgid "Static Cast"
msgstr "Lancement Statique"

#. [object]
#: .\utils\item_list.cfg:5651
msgid "Whenever you destroy something, do not touch it again or you will be dead on the spot."
msgstr "Lorsque vous détruisez quelque chose, n'y touchez plus, sous peine de mourir sur place."

#. [object]
#: .\utils\item_list.cfg:5654
msgid "Shroud of Iron"
msgstr "Linceul de Fer"

#. [object]
#: .\utils\item_list.cfg:5668
msgid "Those armours are not very good, but if you wear more of them at the same time..."
msgstr "Ces armures ne sont pas très bonnes, mais si vous en portez plusieurs en même temps..."

#. [object]
#: .\utils\item_list.cfg:5671
msgid "Lionheart"
msgstr "Cœur de Lion"

#. [object]
#: .\utils\item_list.cfg:5685
msgid "Lions spend twenty hours per day slacking. Yet they are a symbol of bravery. Like our nobles."
msgstr "Les lions passent vingt heures par jour à fainéanter. Pourtant, ils sont un symbole de bravoure. Comme nos nobles."

#. [object]
#: .\utils\item_list.cfg:5688
msgid "Winterclaw"
msgstr "Griffe d'Hiver"

#. [object]
#: .\utils\item_list.cfg:5701
msgid "They come at night. They leave frozen bodies behind. Bodies that awaken."
msgstr "Ils viennent la nuit. Ils laissent derrière eux des corps gelés. Des corps qui s'éveillent."

#. [object]
#: .\utils\item_list.cfg:5704
msgid "Iron Sentinel"
msgstr "Sentinelle de Fer"

#. [object]
#: .\utils\item_list.cfg:5718
msgid "If the defender cannot stop the attacks, he has to kill the enemies before they hurt him."
msgstr "Si le défenseur ne peut pas arrêter les attaques, il doit tuer les ennemis avant qu'ils ne le blessent."

#. [object]
#: .\utils\item_list.cfg:5721
msgid "Beyond the Grasp of Men"
msgstr "Au-delà de l'Emprise des Hommes"

#. [object]
#: .\utils\item_list.cfg:5734
msgid "Fast, evasive and seeing further than most. No man shall catch the unreachable."
msgstr "Rapide, évasif et voyant plus loin que la plupart des gens. Nul ne peut attraper l'inaccessible."

#. [object]
#: .\utils\item_list.cfg:5737
msgid "The Grim Butcher"
msgstr "Le Boucher Macabre"

#. [object]
#: .\utils\item_list.cfg:5753
msgid "Pigs, goats, men... is there a difference? They all taste the same."
msgstr "Porcs, chèvres, hommes... y a-t-il une différence ? Ils ont tous le même goût."

#. [object]
#: .\utils\item_list.cfg:5756
msgid "Rock Solid"
msgstr "Solide comme le Roc"

#. [object]
#: .\utils\item_list.cfg:5767
msgid "In halls of stone... walls are impassable."
msgstr "Dans les halls de pierres... les murs sont infranchissables."

#. [object]
#: .\utils\item_list.cfg:5770
msgid "Sinister Lunacy"
msgstr "Folie Sinistre"

#. [object]
#: .\utils\item_list.cfg:5781
msgid "If there was no lunatic causing the war, there would be no war."
msgstr "S'il n'y avait pas de fou à l'origine de la guerre, il n'y aurait pas de guerre."

#. [object]
#: .\utils\item_list.cfg:5784
#: .\utils\item_list.cfg:9997
msgid "Taxes"
msgstr "Taxes"

#. [object]
#: .\utils\item_list.cfg:5800
#: .\utils\item_list.cfg:10014
msgid "Legends speak of a man who took from the poor and gave to the rich."
msgstr "Les légendes parlent d'un homme qui prenait aux pauvres et donnait aux riches."

#. [object]
#: .\utils\item_list.cfg:5803
msgid "Hellforge Armour of Forging"
msgstr "Armure du Forgeage de la Forge de l'Enfer"

#. [object]
#: .\utils\item_list.cfg:5819
msgid "Forge weapons. Give the forgery to your enemies. They shall see that forged arsenal is not useful."
msgstr "Forgez des armes. Remettez les armes forgées à vos ennemis. Ils verront que l'arsenal forgé n'est pas utile."

#. [object]
#: .\utils\item_list.cfg:5822
msgid "The Killer of Great Magi"
msgstr "Le Tueur de Grands Mages"

#. [object]
#: .\utils\item_list.cfg:5837
msgid "I care not how much better you are. Your crippling overspecialisation will be your downfall."
msgstr "Je ne me soucie pas de savoir si vous êtes meilleur. Votre surspécialisation paralysante sera votre perte."

#. [object]
#: .\utils\item_list.cfg:5840
msgid "The Cannon"
msgstr "Le Canon"

#. [object]
#: .\utils\item_list.cfg:5853
msgid "If I will ever get to you, you will be wrecked!"
msgstr "Si je t'atteins un jour, tu seras anéanti !"

#. [object]
#: .\utils\item_list.cfg:5856
msgid "Worshipper of Darkness"
msgstr "Adorateur des Ténèbres"

#. [object]
#: .\utils\item_list.cfg:5872
msgid "Worshipping the heralds of Light is a heavy burden people think to be pleasant to carry."
msgstr "Vénérer les hérauts de la Lumière est un lourd fardeau que les gens croient agréable à porter."

#. [object]
#: .\utils\item_list.cfg:5875
msgid "Merciless Wake"
msgstr "Sillage Impitoyable"

#. [object]
#: .\utils\item_list.cfg:5888
msgid "Why so much hurry? Go slowly, look around, contemplate, kill whatever you like..."
msgstr "Pourquoi tant de hâte ? Allez-y doucement, regardez autour de vous, contemplez, tuez ce que vous voulez..."

#. [object]
#: .\utils\item_list.cfg:5891
msgid "Thornsword"
msgstr "Épée d'Épines"

#. [object]
#: .\utils\item_list.cfg:5910
msgid ""
"'How can you cut something with that?'\n"
"'It is not for cutting.'"
msgstr ""
"Comment peut-on couper quelque chose avec ça ?\n"
"'Ce n'est pas pour couper'."

#. [object]
#: .\utils\item_list.cfg:5914
msgid "Wisdom of the Ages"
msgstr "Sagesse des Âges"

#. [latent]
#: .\utils\item_list.cfg:5928
msgid "<span color='purple'>+1 to base attacks (requires Search for Wisdom)</span>"
msgstr "<span color='purple'>+1 aux attaques de base (nécessite Recherche de Sagesse)</span>"

#. [latent]
#: .\utils\item_list.cfg:5934
msgid "<span color='purple'>+2 base damage (requires Tracking the Lost Knowledge)</span>"
msgstr "<span color='purple'>+2 dégâts de base (nécessite Traquer la Connaissance Perdue)</span>"

#. [object]
#: .\utils\item_list.cfg:5939
msgid "There is no ancient wisdom. Knowledge must be created in present."
msgstr "Il n'y a pas de sagesse ancienne. La connaissance doit être créée dans le présent."

#. [object]
#: .\utils\item_list.cfg:5942
msgid "Search for Wisdom"
msgstr "Recherche de Sagesse"

#. [latent]
#: .\utils\item_list.cfg:5957
msgid "<span color='purple'>1 more movement point (requires Wisdom of the Ages)</span>"
msgstr "<span color='purple'>1 point de mouvement supplémentaire (nécessite Sagesse des Âges)</span>"

#. [latent]
#: .\utils\item_list.cfg:5963
msgid "<span color='purple'>1 more movement point (requires Tracking the Lost Knowledge)</span>"
msgstr "<span color='purple'>1 point de mouvement supplémentaire (nécessite Traquer la Connaissance Perdue)</span>"

#. [object]
#: .\utils\item_list.cfg:5968
msgid "They look for wisdom. But that is a fool's errand, it never existed."
msgstr "Ils cherchent la sagesse. Mais c'est une entreprise insensée, elle n'a jamais existé."

#. [object]
#: .\utils\item_list.cfg:5971
msgid "Tracking the Lost Knowledge"
msgstr "Traquer la Connaissance Perdue"

#. [latent]
#: .\utils\item_list.cfg:5989
msgid "<span color='purple'>New ability: absorb (1) (requires Wisdom of the Ages)</span>"
msgstr "<span color='purple'>Nouvelle capacité : absorbe (1) (nécessite Sagesse des Âges)</span>"

#. [latent]
#: .\utils\item_list.cfg:5997
msgid "<span color='purple'>New base ranged weapon special: horrid (requires Search for Wisdom)</span>"
msgstr "<span color='purple'>Nouvelle spécialité d'attaque à distance : épouvantable (nécessite la Recherche de Sagesse)</span>"

#. [object]
#: .\utils\item_list.cfg:6006
msgid "If it has been lost, then it must had been created before. Maybe it was never created."
msgstr "S'il a été perdu, c'est qu'il a dû être créé auparavant. Peut-être n'a-t-il jamais été créé."

#. [object]
#: .\utils\item_list.cfg:6009
msgid "Bloodsucker's Potion"
msgstr "Potion du Suceur de Sang"

#. [object]
#: .\utils\item_list.cfg:6011
msgid ""
"<span color='orange'>New base ranged weapon special: drain\n"
"New Ability: blood drinking</span>"
msgstr ""
"<span color='orange'>Nouvelle spécialité d'attaque à distance : drain\n"
"Nouvelle capacité : buveur de sang</span>"

#. [object]
#: .\utils\item_list.cfg:6031
msgid "All this blood. It is yours. You will drink it. You will guzzle it. You will choke on it. You will drown in it."
msgstr "Tout ce sang. Il est à vous. Vous le boirez. Vous l'engloutirez. Vous vous étoufferez avec. Vous vous noierez dedans."

#. [object]
#: .\utils\item_list.cfg:6034
msgid "Theophrastus Redivivus"
msgstr "Theophrastus Redivivus"

#. [latent]
#: .\utils\item_list.cfg:6042
msgid "<span color='purple'>10% to arcane resistance (requires Treatise of the Three Impostors)</span>"
msgstr "<span color='purple'>10 % à la résistance à l'arcane (nécessite le Traité des Trois Imposteurs)</span>"

#. [latent]
#: .\utils\item_list.cfg:6051
msgid "<span color='purple'>New ability: regenerates slightly (requires Al-Fuṣūl wa al-ghāyāt)</span>"
msgstr "<span color='purple'>Nouvelle capacité : régénère légèrement (requiert Al-Fuṣūl wa al-ghāyāt)</span>"

#. [object]
#: .\utils\item_list.cfg:6058
msgid "Difficile est negave Deos, si inconcione quaratur, sed in familliarium, sermone, en consessur facilitimum..."
msgstr "Difficile est negave Deos, si inconcione quaratur, sed in familliarium, sermone, en consessur facilitimum..."

#. [object]
#: .\utils\item_list.cfg:6061
msgid "Treatise of the Three Impostors"
msgstr "Traité des Trois Imposteurs"

#. [latent]
#: .\utils\item_list.cfg:6069
#: .\utils\item_list.cfg:6096
msgid "<span color='purple'>10% to arcane resistance (requires Theophrastus Redivivus)</span>"
msgstr "<span color='purple'>10 % à la résistance à l'arcane (nécessite Theophrastus Redivivus)</span>"

#. [latent]
#: .\utils\item_list.cfg:6078
msgid "<span color='purple'>New ability: exile (requires Al-Fuṣūl wa al-ghāyāt)</span>"
msgstr "<span color='purple'>Nouvelle capacité : exil ( nécessite Al-Fuṣūl wa al-ghāyāt)</span>"

#. [object]
#: .\utils\item_list.cfg:6085
msgid "However important it may be for all men to know the Truth, very few, nevertheless, are acquainted with it..."
msgstr "Quelle que soit l'importance pour tous les hommes de connaître la Vérité, très peu, cependant, la connaissent..."

#. [object]
#: .\utils\item_list.cfg:6088
msgid "Al-Fuṣūl wa al-ghāyāt"
msgstr "Al-Fuṣūl wa al-ghāyāt"

#. [latent]
#: .\utils\item_list.cfg:6105
msgid "<span color='purple'>New ability: frail tide (10) (requires Treatise of the Three Impostors)</span>"
msgstr "<span color='purple'>Nouvelle capacité : marée frêle (10) (nécessite le Traité des Trois Imposteurs)</span>"

#. [object]
#: .\utils\item_list.cfg:6112
msgid ""
"They would not have accepted a spoken lie,\n"
"but whips were raised to strike them,\n"
"traditions were brought to them."
msgstr ""
"Ils n'auraient pas accepté un mensonge oral,\n"
"mais des fouets ont été brandis pour les frapper,\n"
"des traditions leur ont été apportées."

#. [object]
#: .\utils\item_list.cfg:6117
msgid "Hunter of Kings"
msgstr "Chasseur de Rois"

#. [latent]
#: .\utils\item_list.cfg:6126
msgid "<span color='purple'>New ability: frail tide (30) (requires Lost Memoirs of the Inglorious)</span>"
msgstr "<span color='purple'>Nouvelle capacité : marée frêle (10) (nécessite Mémoires Perdues de l'Ignominieux)</span>"

#. [latent]
#: .\utils\item_list.cfg:6134
msgid "<span color='purple'>New ability: conviction (20) (requires Legion Slayer)</span>"
msgstr "<span color='purple'>Nouvelle capacité : conviction (20) (nécessite Tueur de Légion)</span>"

#. [object]
#: .\utils\item_list.cfg:6141
msgid "Nobody knows who he was. Nobody knows where he came from. Nobody knows how to stop him."
msgstr "Personne ne sait qui il était. Personne ne sait d'où il vient. Personne ne sait comment l'arrêter."

#. [object]
#: .\utils\item_list.cfg:6144
msgid "Legion Slayer"
msgstr "Tueur de Légion"

#. [latent]
#: .\utils\item_list.cfg:6157
msgid "<span color='purple'> 2 more movement points (requires Hunter of Kings)</span>"
msgstr "<span color='purple'> 2 points de mouvement supplémentaires (nécessite Chasseur de Rois)</span>"

#. [object]
#: .\utils\item_list.cfg:6164
msgid "Nobody knows how he works. Nobody knows when he strikes. Nobody lives to tell how he looks."
msgstr "Personne ne sait comment il travaille. Personne ne sait quand il frappe. Personne ne vit pour dire de quoi il a l'air."

#. [object]
#: .\utils\item_list.cfg:6167
msgid "Defender of the Faith"
msgstr "Défenseur de la Foi"

#. [object]
#: .\utils\item_list.cfg:6180
msgid "We shall clear the world of this filth!"
msgstr "Nous devons débarrasser le monde de cette saleté !"

#. [object]
#: .\utils\item_list.cfg:6183
msgid "The Unstoppable"
msgstr "L'Innarêtable"

#. [object]
#: .\utils\item_list.cfg:6200
msgid "No one can bargain with him. There is no way to reason with him. He feels no fear. There is nothing at all that would stop him... until the evil is banished."
msgstr "Personne ne peut négocier avec lui. Il n'y a aucun moyen de le raisonner. Il ne ressent aucune peur. Rien ne peut l'arrêter... jusqu'à ce que le mal soit banni."

#. [object]
#: .\utils\item_list.cfg:6203
msgid "Something"
msgstr "Quelque Chose"

#. [object]
#: .\utils\item_list.cfg:6215
msgid "Uhm... I wanted to say... ehm, that... it was... uh... basically... so now, I am saying that... uhm..."
msgstr "Euh... je voulais dire... hum, que... c'était... euh... en gros... donc maintenant, je dis que... heu..."

#. [object]
#: .\utils\item_list.cfg:6218
msgid "The Infidel"
msgstr "L'Infidèle"

#. [object]
#: .\utils\item_list.cfg:6229
msgid "Fidel is dead. Hail the Infidel."
msgstr "Fidel est mort. Vive l'Infidèle."

#. [object]
#: .\utils\item_list.cfg:6232
msgid "The Touch of Death"
msgstr "Le Toucher de la Mort"

#. [object]
#: .\utils\item_list.cfg:6242
msgid "There is no touch of death. But you can take your time to aim at the windpipe from the correct angle..."
msgstr "Il n'y a pas de toucher de la mort. Mais vous pouvez prendre votre temps pour viser la trachée sous le bon angle..."

#. [object]
#: .\utils\item_list.cfg:6245
msgid "The Disease and the Cure"
msgstr "La Maladie et le Remède"

#. [object]
#: .\utils\item_list.cfg:6260
msgid "You are the disease. We are the cure."
msgstr "Vous êtes la maladie. Nous sommes le remède."

#. [object]
#: .\utils\item_list.cfg:6263
msgid "Gvødgührvoḧzzorghkuz"
msgstr "Gvødgührvoḧzzorghkuz"

#. [object]
#: .\utils\item_list.cfg:6275
msgid "Ürhrabgzubruprÿÿrv øẗhnäæzdaz grohruth züürd myyvöthgavrhyd..."
msgstr "Ürhrabgzubruprÿÿrv øẗhnäæzdaz grohruth züürd myyvöthgavrhyd..."

#. [object]
#: .\utils\item_list.cfg:6278
msgid "Rigor Mortis"
msgstr "Rigidité Cadavérique"

#. [object]
#: .\utils\item_list.cfg:6291
msgid "Freeze! I need to aim!"
msgstr "Ne bougez plus ! Je dois viser !"

#. [object]
#: .\utils\item_list.cfg:6294
msgid "Straight out of Nowhere"
msgstr "Tout Droit sorti de Nulle Part"

#. [object]
#: .\utils\item_list.cfg:6307
msgid "Expect the unexpected. Diabolus ex machina."
msgstr "Attendez-vous à l'inattendu. Diabolus ex machina."

#. [object]
#: .\utils\item_list.cfg:6310
msgid "The Jester"
msgstr "Le Bouffon"

#. [object]
#: .\utils\item_list.cfg:6323
msgid "We needed better entertainment. They're in flames now."
msgstr "Nous avions besoin d'un meilleur divertissement. Ils sont en flammes maintenant."

#. [object]
#: .\utils\item_list.cfg:6326
msgid "Organ Grinder"
msgstr "Broyeur d'Organes"

#. [object]
#: .\utils\item_list.cfg:6340
msgid "Keep that man away from me... Hey, keep him away! Do not flee! Aaarghh! Ehhmragehhhd..."
msgstr "Ne laissez pas cet homme s'approcher de moi... Hé, empêchez-le de s'approcher ! Ne fuyez pas ! Aaarghh ! Ehhmragehhhd..."

#. [object]
#: .\utils\item_list.cfg:6343
msgid "The Unrepenting"
msgstr "L'Impénitent"

#. [object]
#: .\utils\item_list.cfg:6363
msgid ""
"I have broken the sacred vow, forgotten the pledge of allegiance, lost my faith.\n"
"I did what I did. I cannot change it, so why should I torment myself with it?"
msgstr ""
"J'ai rompu le vœu sacré, oublié le serment d'allégeance, perdu la foi.\n"
"J'ai fait ce que j'ai fait. Je ne peux pas le changer, alors pourquoi devrais-je me tourmenter avec cela ?"

#. [object]
#: .\utils\item_list.cfg:6367
msgid "Liquid Hatred"
msgstr "Haine Liquide"

#. [object]
#: .\utils\item_list.cfg:6383
msgid "The essence of liquid hatred, purified and distilled."
msgstr "L'essence de la haine liquide, purifiée et distillée."

#. [object]
#: .\utils\item_list.cfg:6386
msgid "The Generous Armour"
msgstr "L'Armure Généreuse"

#. [object]
#: .\utils\item_list.cfg:6404
msgid "Hey there, you are a bad fighter, wear this."
msgstr "Hé là, tu es un mauvais combattant, porte ça."

#. [object]
#: .\utils\item_list.cfg:6407
msgid "Lesser Potion of Invisibility"
msgstr "Potion Mineure d'Invisibilité"

#. [object]
#: .\utils\item_list.cfg:6409
msgid "<span color='orange'>New ability: nightstalk</span>"
msgstr "<span color='orange'>Nouvelle capacité : chasseur nocturne</span>"

#. [object]
#: .\utils\item_list.cfg:6421
msgid "When you are defeated, search for solace in the darkness."
msgstr "Lorsque vous êtes vaincu, cherchez du réconfort dans l'obscurité."

#. [object]
#: .\utils\item_list.cfg:6424
#: .\utils\item_list.cfg:10176
msgid "The Decimator"
msgstr "Le Décimateur"

#. [object]
#: .\utils\item_list.cfg:6438
#: .\utils\item_list.cfg:10191
msgid "Do not get too crazy with that sword."
msgstr "Ne vous acharnez pas trop avec cette épée."

#. [object]
#: .\utils\item_list.cfg:6441
msgid "The Noble Survivor"
msgstr "Le Survivant Noble"

#. [object]
#: .\utils\item_list.cfg:6461
msgid "He wishes that all the nobility could be hung with the guts of priests. That will not work on me."
msgstr "Il souhaite que toute la noblesse soit pendue avec les tripes des prêtres. Cela ne marchera pas avec moi."

#. [object]
#: .\utils\item_list.cfg:6464
msgid "King Salmon's Crown"
msgstr "Couronne du Roi Saumon"

#. [object]
#: .\utils\item_list.cfg:6476
msgid "What? The king has a known name? Now I can no longer call him what I want..."
msgstr "Commun ? Le roi a un nom connu ? Maintenant je ne peux plus l'appeler comme je veux..."

#. [object]
#: .\utils\item_list.cfg:6479
msgid "The Great Truth"
msgstr "La Grande Vérité"

#. [object]
#: .\utils\item_list.cfg:6489
msgid "The Great Truth is that there is no Great Truth."
msgstr "La Grande Vérité est qu'il n'y a pas de Grande Vérité."

#. [object]
#: .\utils\item_list.cfg:6492
msgid "The Predator"
msgstr "Le Prédateur"

#. [object]
#: .\utils\item_list.cfg:6510
msgid "Try not to split from the group."
msgstr "Essayez de ne pas vous séparer du groupe."

#. [object]
#: .\utils\item_list.cfg:6513
msgid "Eidolon's Ring"
msgstr "Anneau d'Eidolon"

#. [latent]
#: .\utils\item_list.cfg:6524
#: .\utils\item_list.cfg:6662
#: .\utils\item_list.cfg:6726
#: .\utils\item_list.cfg:6791
#: .\utils\item_list.cfg:6863
#: .\utils\item_list.cfg:6935
#: .\utils\item_list.cfg:6998
msgid "<span color='purple'>3% to pierce resistance (requires Eidolon's Necklace)</span>"
msgstr "<span color='purple'>3 % à la résistance au perforant (nécessite Collier d'Eidolon)</span>"

#. [latent]
#: .\utils\item_list.cfg:6533
#: .\utils\item_list.cfg:6593
#: .\utils\item_list.cfg:6735
#: .\utils\item_list.cfg:6800
#: .\utils\item_list.cfg:6872
#: .\utils\item_list.cfg:6944
#: .\utils\item_list.cfg:7007
msgid "<span color='purple'>3% to blade resistance (requires Eidolon's Armour)</span>"
msgstr "<span color='purple'>3 % à la résistance au tranchant (nécessite Armure d'Eidolon)</span>"

#. [latent]
#: .\utils\item_list.cfg:6542
#: .\utils\item_list.cfg:6602
#: .\utils\item_list.cfg:6671
