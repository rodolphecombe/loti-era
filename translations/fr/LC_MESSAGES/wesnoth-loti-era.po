#. [unit_type], id=Abomination LotI, race=undead
#: .\units\Abomination.cfg:4
msgid "Abomination"
msgstr "Abomination"

#. [unit_type], id=Abomination LotI, race=undead
#: .\units\Abomination.cfg:19
msgid "Horror tales about terrifying undead usually lie. They describe ghasts as the most nightmarish beings that ever existed. And that is just plain wrong. There is Abomination, a mutated kind of ghast that scares even the most courageous monster hunters. It has literally a dozen mouths, most of them belonging to ghoul homunculi attached to its body with tentacles. "
msgstr "Les histoires d'horreur à propos de morts-vivants terrifiants mentent habituellement. Elles décrivent les abominations comme les êtres les plus cauchemardesques ayant jamais existé. Et c'est complètement faux. Il y a l'Atrocité, une sorte d'abomination mutée qui effraye même les plus courageux des chasseurs de monstres. Elle a littéralement des douzaines de bouches, la plupart appartenant à des goules homoncules rattachées à son corps par des tentacules."

#. [advancement], id=bite-eager
#: .\units\Abomination.cfg:136
msgid "dealing 50% more damage to poisoned enemies"
msgstr "inflige 50% de dégâts supplémentaire contre les ennemis empoisonnés"

#. [advancement], id=bite2-swarn
#: .\units\Abomination.cfg:154
msgid "biting faster if healthy"
msgstr "mordre plus vite si en bonne santé"

#. [advancement], id=bite2-leech
#. [advancement], id=fangs2-leech
#: .\units\Abomination.cfg:173
#: .\units\Goblin_Ravager.cfg:254
#: .\units\Werewolf_Rider.cfg:182
#: .\units\mainline\Wolf_Dire.cfg:15
msgid "feasting on enemies when biting"
msgstr "se régaler des ennemis en mordant"

#. [advancement], id=murderlust
#: .\units\Abomination.cfg:191
msgid "healing more from kills"
msgstr "se soigner plus des mises à mort"

#. [advancement], id=regurgitate1
#: .\units\Abomination.cfg:213
msgid "able to regurgitate culinary feasts as Walking Corpses"
msgstr "capable de régurgiter les festins culinaires en tant que Zombi"

#. [advancement], id=regurgitate2
#: .\units\Abomination.cfg:231
msgid "able to regurgitate culinary feasts as Ghouls"
msgstr "capable de régurgiter les festins culinaires en tant que Goule"

#. [advancement], id=corrosive_blood
#. [advancement], id=corrosive_blood2
#: .\units\Abomination.cfg:252
#: .\units\Abomination.cfg:274
msgid "damaging adjacent enemies when hit more"
msgstr "blesser plus les ennemis adjacents quand touchée"

#. [advancement], id=despair
#: .\units\Abomination.cfg:296
msgid "causing nearby enemies to deal less damage"
msgstr "faire infliger moins de dégâts aux ennemis proches"

