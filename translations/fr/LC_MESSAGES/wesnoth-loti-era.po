#: .\utils\amla.cfg:5397
msgid "blizzard"
msgstr "blizzard"

#. [unit_type], id=Soul Shooter LotI, race=undead
#: .\units\Soul_Shooter.cfg:4
msgid "Soul Shooter"
msgstr "Décocheur d'Âme"

#. [unit_type], id=Soul Shooter LotI, race=undead
#: .\units\Soul_Shooter.cfg:17
msgid "Entrapped by the evil of their existence, their victims' souls frequently remain on the battlefield, too scared to leave into the world of the dead. Soul Shooters can exploit them by binding them into their arrows, making them incredibly powerful."
msgstr "Piégé par le mal qu'ils ont fait pendant leur vie, les âmes de ses victimes restent fréquemment sur le champ de bataille, trop effrayées de partir dans le monde des morts. Les Décocheurs d'Âme peuvent les exploiter en les liant à leurs flèches, les rendant incroyablement puissantes. "

#. [advancement], id=bow-leech
#: .\units\Soul_Shooter.cfg:183
msgid "leeching health from enemies with bow"
msgstr "drainer de la santé des ennemis avec l'arc"

#. [advancement], id=bow-infect
#: .\units\Soul_Shooter.cfg:200
msgid "turning enemies into undead with poison from bow"
msgstr "transformer les ennemis en morts-vivants avec le poison de l'arc"

#. [advancement], id=arcane
#: .\units\Soul_Shooter.cfg:219
msgid "able to shoot cursed arcane arrows (new attack)"
msgstr "capable de tirer des flèches d'arcane maudites (nouvelle attaque)"

#. [effect], apply_to=bonus_attack, type=arcane, range=ranged
#: .\units\Soul_Shooter.cfg:226
