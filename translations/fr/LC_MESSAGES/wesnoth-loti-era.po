#: .\units\Sky_Goblin.cfg:4
msgid "Sky Goblin"
msgstr "Gobelin du Ciel"

#. [unit_type], id=Sky Goblin LotI, race=goblin
#: .\units\Sky_Goblin.cfg:18
msgid "The best of goblin fighters get the right to ride giant birds, to scout terrains ahead and occasionally attack vulnerable units that they manage to approach."
msgstr "Les meilleurs guerriers gobelins obtiennent le droit de monter des oiseaux géants, pour éclairer le terrain et occasionnellement attaquer les unités vulnérables qu'ils réussissent à approcher. "

#. [advancement], id=bow-precise
#: .\units\Sky_Goblin.cfg:137
msgid "more precise with the bow"
msgstr "plus précis avec l'arc"

#. [advancement], id=escape
