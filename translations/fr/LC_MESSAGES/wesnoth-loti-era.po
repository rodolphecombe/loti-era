#: .\lua\hacks.lua:14
msgid "infected: This unit is infected. It will become undead after death, unless cured by a healer or by standing on a village."
msgstr "infecté : Cette unité est infectée. Elle deviendra morte-vivante après sa mort, sauf si elle est soignée par un guérisseur ou en se tenant sur un village."

#: .\lua\hacks.lua:20
msgid "in flames: This unit is in flames. It will lose 16 HP per turn, unless cured by a healer or by standing on a village."
msgstr "en flammes : Cette unité est en flammes. Elle perd 16 PV par tour, sauf si elle est soignée par un guérisseur ou en se tenant sur un village."

#: .\lua\hacks.lua:26
msgid "unslowable: This unit cannot be affected by slow."
msgstr "unralentissable : Cette unité est immunisée au ralentissement"

#: .\lua\hacks.lua:32
msgid "unpoisonable: This unit cannot be affected by poison."
msgstr "inempoisonnable : Cette unité est immunisée au poison."

#: .\lua\hacks.lua:38
msgid "undrainable: This unit cannot be drained."
msgstr "indrainable : Cette unité ne peut pas être drainée."

#: .\lua\hacks.lua:44
msgid "unplagueable: This unit will not return as undead when killed by a plague weapon special."
msgstr "vacciné : Cette unité ne reviendra pas sous la forme d'un mort-vivant si elle est tuée par une attaque avec la capacité peste."

