#. [unit_type], id=Predator LotI, race=human
#: .\units\Predator.cfg:5
msgid "Predator"
msgstr "Prédateur"

#. [unit_type], id=Predator LotI, race=human
#: .\units\Predator.cfg:19
msgid "Master huntsmen often get to like hunting more than anything else. Their deadly passion guides them, and they care only a little if their prey is human or animal. These predators may attack anything they spot, if it is not too numerous. Provided that one has enough guards around, it is possible to parlay with them, or even to employ them."
msgstr "Les maîtres traqueurs finissent souvent par préférer la chasse à toute autre chose. Leur passion meurtrière les guides et ils ne se soucient peu de savoir si leur proie est humaine ou animale. Ces prédateurs peuvent attaquer n'importe quoi à vue, s'ils ne sont pas trop nombreux. A condition d'avoir assez de gardes autours, il est possible de parlementer avec eux, voir même de les employer."

#. [advancement], id=bow-precise2
#: .\units\Predator.cfg:177
msgid "shooting unbelievably precisely"
msgstr "tirer incroyablement précisement"

#. [advancement], id=execution
#: .\units\Predator.cfg:197
msgid "able to deal heavy damage with a single shot (new attack)"
msgstr "capable d'infliger de gros dégâts en un tir (nouvelle attaque)"

#. [advancement], id=bow-hunting-humans
#: .\units\Predator.cfg:216
msgid "very good at slaying humans"
msgstr "très doué pour abattre les humains"

#. [advancement], id=bow-hunting-imps
#: .\units\Predator.cfg:234
